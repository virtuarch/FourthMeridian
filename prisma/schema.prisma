generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // In production/staging (Supabase), set DATABASE_URL to the Transaction Pooler URL
  // (port 6543, ?pgbouncer=true) for Vercel serverless compatibility.
  // Set DIRECT_URL to the direct connection URL (port 5432) for migrations.
  // In local dev both can point to the same Docker Postgres URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum AccountType {
  checking
  savings
  investment
  crypto
  debt
  other
}

enum TransactionCategory {
  Income
  Transfer
  Groceries
  Dining
  Shopping
  Travel
  Subscriptions
  Utilities
  Interest
  Payment
  Other
  // Investment transactions
  Buy
  Sell
  Dividend
  Split
  Fee
}

enum RiskLevel {
  low
  medium
  high
}

enum PlaidItemStatus {
  ACTIVE // syncing normally
  NEEDS_REAUTH // user must re-authenticate via Plaid Link
  ERROR // unrecoverable error — see errorCode
  REVOKED // all accounts removed; itemRemove() was called
}

/// Per-Item Plaid Investments product consent state, derived from the `item`
/// object returned by accountsGet (consented_products / available_products /
/// billed_products) and, for pre-DTM Items, from probing
/// investmentsHoldingsGet once. Gates the holdings step of refresh so we
/// never repeatedly call an endpoint Plaid will reject with
/// ADDITIONAL_CONSENT_REQUIRED. Re-derived on every refresh, so it self-heals
/// after the user grants consent via Link update mode. See
/// docs/investigations/PLAID_INVESTMENTS_CONSENT_INVESTIGATION.md.
enum PlaidInvestmentsConsent {
  ENABLED // user consented to investments (or legacy probe succeeded)
  CONSENT_REQUIRED // supported, but user must grant consent via Link update mode
  UNSUPPORTED // Plaid Investments not available for this Item
}

/// D2 (Phase 2, Step 1A): generalizes PlaidItemStatus across all connection
/// types. Mirrors PlaidItemStatus exactly. PlaidItem keeps its own enum
/// unchanged — this is additive, not a replacement. Not yet used by any
/// application code.
enum ConnectionStatus {
  ACTIVE // syncing normally / valid credential
  NEEDS_REAUTH // user must re-authenticate
  ERROR // unrecoverable error — see errorCode
  REVOKED // credential revoked / connection removed
}

/// D2 (Phase 2, Step 1A): identifies which kind of provider a Connection
/// represents. Extensible — new values can be appended later without a
/// breaking migration. Not yet used by any application code.
enum ProviderType {
  PLAID
  MANUAL
  WALLET
  CSV
  EXCHANGE
  BROKERAGE
}

/// Renamed from Workspace -> Space (Fourth Meridian Phase 1 naming migration).
/// DB1 (2026-07): physical enum type renamed WorkspaceType -> SpaceType, so the
/// DB type name now matches and no @@map is needed.
enum SpaceType {
  PERSONAL
  SHARED
}

/// Semantic category for a Space — drives default UI labels, section presets, and AI context.
/// Renamed from WorkspaceCategory -> SpaceCategory (DB1: physical enum type renamed to match).
enum SpaceCategory {
  PERSONAL
  HOUSEHOLD
  FAMILY
  BUSINESS
  PROPERTY
  VEHICLE
  TRIP
  INVESTMENT
  EQUIPMENT
  GOAL // legacy — kept for backward compat
  RETIREMENT
  DEBT_PAYOFF
  EMERGENCY_FUND
  CUSTOM
  OTHER
}

/// Tabs available on the Space planning dashboard.
/// Each SpaceDashboardSection belongs to one tab.
/// Renamed from WorkspaceDashboardTab -> SpaceDashboardTab (DB1: physical enum type renamed to match).
enum SpaceDashboardTab {
  OVERVIEW
  GOALS
  ACCOUNTS
  DEBT
  INVESTMENTS
  RETIREMENT
  ACTIVITY
  SETTINGS
}

/// Renamed from WorkspaceMemberRole -> SpaceMemberRole (DB1: physical enum type renamed to match).
enum SpaceMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

/// Soft-membership state. REMOVED = kicked by OWNER/ADMIN. LEFT = self-removed.
/// Row is never deleted so audit history is preserved.
/// Renamed from WorkspaceMemberStatus -> SpaceMemberStatus (DB1: physical enum type renamed to match).
enum SpaceMemberStatus {
  ACTIVE
  REMOVED
  LEFT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

/// Controls how a FinancialAccount is visible to a Space it has been shared into.
/// BALANCE_ONLY added for privacy-sensitive sharing (e.g. a partner sees total but not institution).
/// FULL replaces the old SHARED value; SHARED kept temporarily for Account (legacy) rows.
enum VisibilityLevel {
  PRIVATE // only the owning Space can see this account
  BALANCE_ONLY // other Space sees the balance total, no institution or transactions
  SUMMARY_ONLY // qualitative summary, no raw numbers
  SHARED // legacy — maps to FULL; kept for backward compat with Account model
  FULL // fully visible to all Space members (new canonical value)
}

/// Whether a SpaceAccountLink is currently active or has been revoked.
/// (Originally introduced for WorkspaceAccountShare, retired v2.5-A Phase 4c.)
enum ShareStatus {
  ACTIVE
  REVOKED
}

/// D3 (Phase 2): which role a SpaceAccountLink row plays for its account.
/// Exactly one HOME row exists per financialAccountId (the account's
/// primary/owning Space, replacing ownerSpaceId/ownerUserId); any number of
/// SHARED rows may exist (replacing WorkspaceAccountShare). Enforced at the DB
/// level (KD-5) by the partial unique index
/// `SpaceAccountLink_one_home_per_account` — UNIQUE (financialAccountId) WHERE
/// kind = 'HOME' — added via a raw-SQL migration because Prisma has no
/// partial-unique-index syntax (see
/// prisma/migrations/20260702170000_kd5_home_partial_unique_index).
/// computeLinkKind in lib/accounts/space-account-link.ts remains the source of
/// HOME/SHARED assignment; the index only backstops it against concurrent
/// HOME races.
enum SpaceAccountLinkKind {
  HOME
  SHARED
}

/// Lifecycle of a suspected duplicate pair surfaced by the system.
/// CONFIRMED_DUPLICATE is written automatically today by the merge path in
/// lib/accounts/reconcile.ts (mergeArchivedDuplicateIntoCanonical) — there is
/// no gate that blocks a merge pending review. PENDING / NOT_DUPLICATE /
/// IGNORED are not written by any code path today; they're kept, unused, in
/// case a future manual-review feature is layered on top of this ledger.
enum DuplicateStatus {
  PENDING // flagged, awaiting user review
  CONFIRMED_DUPLICATE // user confirmed these are the same real-world account
  NOT_DUPLICATE // user confirmed these are different accounts
  IGNORED // user dismissed without deciding
}

/// How an automatic merge in lib/accounts/reconcile.ts was detected. Always
/// populated on rows written by that path — there is no ambiguous/unset case
/// today.
enum DuplicateDetectionSource {
  PROVIDER_IDENTITY_MATCH // exact plaidAccountId or walletAddress match
  FINGERPRINT_MATCH // loose institution + mask + type + name match
  SIBLING_CONSOLIDATION // multiple matching rows reduced to one canonical row, independent of the top-level trigger
}

/// Whether a FinancialAccount is owned by an individual user or by a Space entity.
/// SPACE was renamed from WORKSPACE in the Fourth Meridian Phase 1 naming migration —
/// this is a real `ALTER TYPE ... RENAME VALUE` migration (see
/// prisma/migrations/*_rename_account_owner_type_workspace_to_space/), not a @map,
/// because the existing label is genuinely renamed end-to-end. The rename is
/// metadata-only in Postgres: existing rows keep referencing the same enum OID,
/// so no row data is rewritten and no UPDATE statement is needed.
enum AccountOwnerType {
  USER // personal account owned by a single user
  SPACE // Space-level account (e.g. a joint or business account)
}

enum UserRole {
  USER // normal authenticated user
  SYSTEM_ADMIN // platform administration — not for daily use; requires TOTP (M3)
}

enum EmploymentStatus {
  EMPLOYED
  UNEMPLOYED
  SELF_EMPLOYED
  STUDENT
  RETIRED
}

enum UseCase {
  PERSONAL_TRACKING // personal budget + net worth tracking
  BUSINESS_VENTURES // business / LLC financial oversight
  INVESTING // portfolio + market focus
  DEBT_MANAGEMENT // debt payoff planning
  OTHER
}

/// Category of a financial goal — drives default labels and AI context.
enum GoalCategory {
  EMERGENCY_FUND
  DEBT_PAYOFF
  HOME_PURCHASE
  VEHICLE_PURCHASE
  TRIP
  BUSINESS
  INVESTMENT
  EQUIPMENT
  EDUCATION
  GENERAL
}

/// Lifecycle state of a SpaceGoal.
enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

/// Governs which fields and tracking mode apply to a SpaceGoal.
enum GoalType {
  FINANCIAL // Save $X by a target date
  HABIT // Behavioral goal tracked by streak / check-ins
  SPENDING_LIMIT // Keep a spending category under $X / month
  DEBT_REDUCTION // Pay down a specific debt account by $X or X%
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ficoScore removed — now lives in CreditScore for time-series tracking.
// Profile fields (DOB, employment, useCase) feed the AI advice engine.
// dateOfBirthEncrypted is AES-256-GCM (same key as Plaid tokens).
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  username             String?           @unique
  name                 String?
  firstName            String?
  lastName             String?
  dateOfBirthEncrypted String? // AES-256-GCM encrypted ISO date string
  employmentStatus     EmploymentStatus?
  useCase              UseCase?
  passwordHash         String? // bcrypt hash, cost 12
  totpSecret           String? // TOTP seed, stored encrypted (used in M3)
  totpEnabled          Boolean           @default(false)
  role                 UserRole          @default(USER)
  preferredSpaceId     String?           // soft ref — Space the user lands on after login
  passwordResetToken   String?           @unique
  passwordResetExpiry  DateTime?
  forcePasswordReset   Boolean           @default(false) // set true by admin; user must change on next login
  // OPS-1 S2b — email verification seam. `emailVerifiedAt` is the verification
  // state (null = unverified; timestamp = when verified). Token columns mirror
  // the password-reset pattern (hashed at rest, single outstanding token, 1h
  // TTL). STORED-BUT-NOT-CONSUMED in S2b: new signups receive a verification
  // email and these are written, but NO route/gate reads them yet. Existing
  // users are backfilled to verified by the S2b migration so they are never
  // treated as unverified.
  emailVerifiedAt         DateTime?
  emailVerificationToken  String?        @unique
  emailVerificationExpiry DateTime?
  // OPS-2 S3a — authenticated email-change seam. `pendingEmail` holds the
  // requested new address (not yet active); the token columns mirror the
  // verification/reset pattern (hashed at rest, single outstanding token, 1h
  // TTL). NOT swapped until the S3b confirm consumer lands. `pendingEmail` is
  // intentionally NOT @unique — final uniqueness is enforced at swap against
  // the live `email @unique`.
  pendingEmail            String?
  emailChangeToken        String?        @unique
  emailChangeExpiry       DateTime?
  // OPS-2 S4 — account deactivation. Null = active; timestamp = when the user
  // deactivated. Deactivated ≠ deleted: all data, Space memberships, and
  // PlaidItems stay intact — only login is gated (lib/auth.ts +
  // /api/auth/pre-login) and the bank-sync cron skips the user's items
  // (jobs/sync-banks.ts). Cleared by the explicit reactivation leg of login
  // (`reactivate` credential flag; requires full auth incl. TOTP).
  deactivatedAt           DateTime?
  // OPS-2 S7a — account-deletion foundations. Null = not scheduled for
  // deletion. deletionRequestedAt records WHEN the user asked to delete;
  // deletionScheduledAt is when the purge becomes due (requestedAt + grace).
  // Pending-deletion reuses deactivatedAt as the login/sync lockout (set
  // alongside these in S7b); deletionScheduledAt is the discriminator the
  // login gate reads to show "pending deletion — cancel?" instead of the
  // deactivation message. Cleared together by the login cancelDeletion leg
  // (lib/auth.ts, mirrors the S4 reactivation leg). No purge/cron/route in
  // S7a — those are S7b/S7c. See OPS2_S7_ACCOUNT_DELETION_INVESTIGATION.md.
  deletionRequestedAt     DateTime?
  deletionScheduledAt     DateTime?
  lastBriefViewedAt    DateTime? // set when user views the Daily Brief page
  // MC1 Phase 3 (D-1/D-2) — the user's DEFAULT reporting currency. A default
  // ONLY: it seeds reportingCurrency for Spaces this user creates (copy-once
  // at POST /api/spaces) and denominates nothing by itself. NO retroactive
  // inheritance — editing this never re-denominates existing Spaces; the
  // Space's own value is the only one consulted for Space-scoped totals.
  reportingCurrency    String            @default("USD")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  spaces                SpaceMember[]
  sentInvites           SpaceInvite[]          @relation("SentInvites")
  receivedInvites       SpaceInvite[]          @relation("ReceivedInvites")
  plaidItems            PlaidItem[]
  connections           Connection[] // D2 — PLAID rows created/updated by lib/plaid/exchangeToken.ts; read by app/api/plaid/link-token
  importBatches         ImportBatch[] // D2 Step 4D — populated by the import pipeline (app/api/accounts/[id]/import)
  importMappingProfiles ImportMappingProfile[] // D2 (Phase 2, Step 4D-5b) — additive; display-only creator ref, not an authorization boundary
  ownedAccounts         Account[] // legacy: accounts this user connected/created
  creditScores          CreditScore[]
  auditLogs             AuditLog[]

  // Security
  recoveryCodes RecoveryCode[]
  sessions      UserSession[]

  // New financial account relations
  financialAccounts        FinancialAccount[]  @relation("UserOwnedFinancialAccounts")
  accountConnections       AccountConnection[] @relation("UserConnectedAccounts")
  createdFinancialAccounts FinancialAccount[]  @relation("FinancialAccountCreator") // D11 — accounts this user created/connected, independent of ownerType

  // Member revocation (who revoked whom)
  revokedMembers SpaceMember[] @relation("RevokedByUser")

  // Goal creation
  createdGoals SpaceGoal[] @relation("GoalCreator")

  // SpaceAccountLink (D3) — the sole account-link path since WorkspaceAccountShare
  // was retired (v2.5-A Phase 4c). Tracks who added/revoked links.
  addedSpaceAccountLinks   SpaceAccountLink[] @relation("SpaceAccountLinkAdder")
  revokedSpaceAccountLinks SpaceAccountLink[] @relation("SpaceAccountLinkRevoker")

  // DuplicateAccountCandidate — tracks who resolved the review
  resolvedDuplicates DuplicateAccountCandidate[] @relation("DuplicateResolver")
}

// ─────────────────────────────────────────────────────────────────────────────
// Space (renamed from Workspace — Fourth Meridian Phase 1 naming migration)
// Container for all financial data. Every user auto-receives one PERSONAL
// Space on registration. Additional SHARED Spaces can be created or
// joined (Hogan Family, Atlanta Duplex LLC, etc.)
// category provides semantic context for the Space (e.g. HOUSEHOLD, BUSINESS).
// DB1 (2026-07): the physical table was renamed Workspace -> Space, so the
// @@map is gone and the DB table name now matches the model.
// ─────────────────────────────────────────────────────────────────────────────

model Space {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        SpaceType     @default(PERSONAL)
  category    SpaceCategory @default(PERSONAL)
  isPublic    Boolean       @default(false) // SHARED Spaces can be listed publicly
  // MC1 Phase 3 (D-1/D-2/D-4) — the AUTHORITATIVE reporting currency for every
  // aggregate, snapshot stamp, chart, and AI total computed within this Space.
  // Seeded copy-once from the creator's User.reportingCurrency at creation;
  // thereafter owned by the Space alone (no live inheritance). Changing it is
  // FORWARD-ONLY: live aggregates re-denominate on the next read, snapshots
  // stamp the new currency from the next write, and existing snapshot rows
  // keep their stamps — history is never rewritten. Allowed values: FX_BASE +
  // SUPPORTED_QUOTES (lib/fx/config.ts), enforced at the API boundary.
  // Nothing reads this until the Phase 3 flip slices (3–6).
  reportingCurrency String @default("USD")

  // ── Lifecycle (mirrors SpaceGoal's archive/trash pattern) ─────────────────
  // archivedAt: hidden from normal nav, fully intact, restorable any time.
  // deletedAt:  moved to trash, hidden from normal nav, restorable until
  //             permanently deleted. Trashing always clears archivedAt so a
  //             Space is never in both states at once. PERSONAL
  //             Spaces cannot be archived, trashed, or permanently
  //             deleted (enforced in the API layer, not the schema).
  archivedAt DateTime?
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       SpaceMember[]
  invites       SpaceInvite[]
  accounts      Account[] // legacy account relation
  snapshots     SpaceSnapshot[]
  aiAgent       AiAgent?
  adviceHistory AiAdvice[]
  auditLogs     AuditLog[]

  // New financial account relations
  // SpaceAccountLink (D3) — the sole account-link path since WorkspaceAccountShare
  // was retired (v2.5-A Phase 4c).
  accountLinks           SpaceAccountLink[]
  ownedFinancialAccounts FinancialAccount[]      @relation("SpaceOwnedFinancialAccounts")
  goals                  SpaceGoal[]
  dashboardSections      SpaceDashboardSection[]
  // ImportMappingProfile (D2, Phase 2, Step 4D-5b) — additive; Space-scoped
  // saved column mappings, auto-used by the import pipeline when they match
  // an upload's headers. See
  // docs/initiatives/d2/implementation/D2_STEP4D5B_IMPLEMENTATION_PLAN.md.
  importMappingProfiles  ImportMappingProfile[]

  @@index([type])
  @@index([isPublic])
  @@index([archivedAt])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceMember (renamed from WorkspaceMember)
// Join table linking users to Spaces with roles.
// status: ACTIVE (normal), REMOVED (kicked), LEFT (self-removed).
// Rows are never deleted — status update preserves audit history.
// When status becomes REMOVED or LEFT, all SpaceAccountLink records
// contributed by that user are revoked.
// ─────────────────────────────────────────────────────────────────────────────

model SpaceMember {
  id       String            @id @default(cuid())
  spaceId  String
  space    Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     SpaceMemberRole   @default(MEMBER)
  status   SpaceMemberStatus @default(ACTIVE)
  joinedAt DateTime          @default(now())

  // Populated when status transitions to REMOVED or LEFT
  revokedAt   DateTime?
  revokedById String?
  revokedBy   User?     @relation("RevokedByUser", fields: [revokedById], references: [id], onDelete: SetNull)

  @@unique([spaceId, userId])
  @@index([spaceId])
  @@index([userId])
  @@index([spaceId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceInvite (renamed from WorkspaceInvite)
// Grant-only access. Only existing members with OWNER or ADMIN role can invite.
// Users cannot request access — they can only accept or decline an invite.
// ─────────────────────────────────────────────────────────────────────────────

model SpaceInvite {
  id            String          @id @default(cuid())
  spaceId       String
  space         Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  invitedById   String
  invitedBy     User            @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUserId String
  invitedUser   User            @relation("ReceivedInvites", fields: [invitedUserId], references: [id], onDelete: Cascade)
  role          SpaceMemberRole @default(MEMBER)
  status        InviteStatus    @default(PENDING)
  createdAt     DateTime        @default(now())
  expiresAt     DateTime?
  seenAt        DateTime? // set when invited user first views the invite

  @@unique([spaceId, invitedUserId])
  @@index([invitedUserId])
  @@index([spaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AiAgent
// One agent per Space. Owns all advice and (future) memory for that
// Space. Created automatically when a Space is created.
// ─────────────────────────────────────────────────────────────────────────────

model AiAgent {
  id           String    @id @default(cuid())
  spaceId      String    @unique
  space        Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name         String
  // D4 — optional restriction layer for AI context assembly.
  // When empty (default), the full template manifest is used.
  // When set, the builder assembles the intersection of the template manifest
  // and these keys. Values are ContextDomain string keys (e.g. "accounts").
  // NOT the primary declaration — the domain manifest (derived from SpaceCategory
  // or, after D9, from SpaceTemplate.contextDomains) is authoritative.
  agentScope   String[]
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  adviceHistory AiAdvice[]

  @@index([spaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PlaidItem
// Stays on User — it is a credential (OAuth token), not a Space asset.
// One item per institution; a single token covers all accounts at that bank.
// Accounts derived from this item are created as FinancialAccount rows.
// ─────────────────────────────────────────────────────────────────────────────

model PlaidItem {
  id                  String                   @id @default(cuid())
  userId              String
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalItemId      String                   @unique // provider's item/connection id (Plaid item_id today)
  institutionId       String // Plaid's institution_id (e.g. "ins_3")
  institutionName     String // human-readable (e.g. "Chase")
  encryptedToken      String // AES-256-GCM encrypted access token — NEVER plaintext
  status              PlaidItemStatus          @default(ACTIVE)
  cursor              String? // /transactions/sync cursor for incremental sync
  errorCode           String? // last Plaid error code when status = ERROR
  lastSyncedAt        DateTime?
  // D2 Step 7B — last manual "Refresh"/"Sync Now" attempt (success or
  // failure), distinct from lastSyncedAt above (also written by the
  // scheduled sync job). Gates the manual-refresh cooldown only; the
  // scheduler never reads or writes this field.
  lastManualRefreshAt DateTime?
  // Investments consent state — null = unknown / never derived (all Items
  // predating this column). Written by lib/plaid/refresh.ts and
  // lib/plaid/exchangeToken.ts; the future "Enable Investment Holdings" UI
  // renders when this is CONSENT_REQUIRED.
  investmentsConsent  PlaidInvestmentsConsent?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  accounts    Account[] // legacy relation
  connections AccountConnection[] // new relation

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Connection (D2, Phase 2 — LIVE for PLAID: rows are created/updated by
// lib/plaid/exchangeToken.ts and read by app/api/plaid/link-token; other
// provider types not yet populated).
// Provider-agnostic generalization of the credential/login layer PlaidItem
// represents today. PlaidItem is NOT migrated or modified by this step — it
// continues to serve all existing Plaid behavior unchanged. Connection exists
// so future, non-Plaid providers (wallets with xpub/watch-only, exchanges,
// brokerages, CSV) have a home that isn't shaped like Plaid.
// See docs/architecture/D2_PROVIDER_CONNECTION_ARCHITECTURE.md.
// ─────────────────────────────────────────────────────────────────────────────

model Connection {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             ProviderType
  externalConnectionId String? // provider's login/connection id, where one exists
  credential           String? // encrypted; null for MANUAL; xpub/descriptor for WALLET watch-only — NEVER a private key
  status               ConnectionStatus @default(ACTIVE)
  cursor               String? // sync cursor, where the provider supports one
  errorCode            String?
  lastSyncedAt         DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  accountConnections        AccountConnection[]
  // ProviderAccountIdentity (D2) — populated (Step 1C backfill + Step 2 dual-write).
  providerAccountIdentities ProviderAccountIdentity[]
  // ImportBatch (D2 Step 4D) — populated by the import pipeline.
  importBatches             ImportBatch[]

  @@index([userId])
  @@index([provider])
}

// ─────────────────────────────────────────────────────────────────────────────
// ProviderAccountIdentity (D2, Phase 2, Step 1B schema; Step 1C-A backfilled
// PLAID rows; Step 2A added a PLAID-only dual-write — see
// app/api/plaid/exchange-token/route.ts and lib/accounts/provider-identity.ts).
// Generalizes the ad hoc provider-identity columns on FinancialAccount
// (plaidAccountId, walletAddress) into one row per (provider,
// externalAccountId). FinancialAccount's existing provider columns remain
// the source of truth and are NOT removed by this step. WALLET is not yet
// backfilled or dual-written — see
// docs/initiatives/d2/investigations/D2_STEP1C_C_WALLET_IDENTITY_COLLISION_INVESTIGATION.md. PLAID read
// cutover is COMPLETE (Steps 3C–3F): sync, refresh, reconcile, and
// exchange-token resolve identities here first, with a warn-and-fallback to the
// legacy plaidAccountId lookup whose removal is gated on a production
// observation window (D2 Step 7 Stabilization).
// See docs/architecture/D2_PROVIDER_CONNECTION_ARCHITECTURE.md §2, §8, §9.
// ─────────────────────────────────────────────────────────────────────────────

model ProviderAccountIdentity {
  id                 String           @id @default(cuid())
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  connectionId       String?
  connection         Connection?      @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  provider           ProviderType
  externalAccountId  String
  metadata           Json?
  createdAt          DateTime         @default(now())

  // D2 Step 1D — multi-account correction. A provider identity (e.g. a
  // wallet address) is a public external fact; a FinancialAccount is a
  // private Fourth Meridian object. Multiple FinancialAccount rows
  // (different owners' private interpretations of the same address, or
  // future public/watch-Space interpretations) may legitimately share one
  // externalAccountId — each gets its own row here, distinguished by
  // financialAccountId. The constraint below was previously
  // @@unique([provider, externalAccountId]) alone, which made that
  // impossible (at most one FinancialAccount could ever hold a given
  // identity, globally). See
  // docs/initiatives/d2/implementation/D2_STEP1D_PROVIDER_ACCOUNT_IDENTITY_MULTI_ACCOUNT_CORRECTION.md.
  // PLAID is unaffected: FinancialAccount.plaidAccountId already carries its
  // own independent @unique, so this relaxation doesn't change PLAID's
  // real-world uniqueness guarantee.
  @@unique([provider, externalAccountId, financialAccountId])
  // Defense-in-depth: at most one identity row per (provider,
  // financialAccountId) — formalizes an invariant
  // dualWriteProviderAccountIdentity() already relies on (find-by-
  // {financialAccountId, provider}, then create-or-update-in-place; never
  // creates a second row for the same pair).
  @@unique([provider, financialAccountId])
  @@index([financialAccountId])
  @@index([connectionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Account (LEGACY — kept temporarily during migration)
// Will be removed once all data is migrated to FinancialAccount +
// AccountConnection + SpaceAccountLink and validated in production
// (v2.5-B follow-up — gated on the Phase 0 prod counts; see
// docs/investigations/V25A_PHASE0_SEAM_RETIREMENT_READINESS.md §6).
// Do not add new features here; use FinancialAccount instead.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id               String          @id @default(cuid())
  spaceId          String
  space            Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  ownerId          String? // who connected this account; nullable (SetNull on user delete)
  owner            User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  visibilityLevel  VisibilityLevel @default(PRIVATE)
  name             String
  type             AccountType
  institution      String
  balance          Float           @default(0) // current/ledger balance
  availableBalance Float? // Plaid: balance after pending transactions clear
  creditLimit      Float? // credit cards: limit from Plaid or manual entry
  currency         String          @default("USD")
  lastUpdated      DateTime        @default(now())
  deletedAt        DateTime? // soft delete — hides from UI, preserves history

  // Plaid — token lives on PlaidItem, not here
  plaidAccountId String?    @unique // Plaid's account_id for this specific account
  plaidItemDbId  String? // FK → PlaidItem.id (our internal id)
  plaidItem      PlaidItem? @relation(fields: [plaidItemDbId], references: [id])

  // Crypto self-custody fields (wallet address accounts only)
  walletAddress String?
  walletChain   String?
  nativeBalance Float?
  syncStatus    String? @default("pending")

  holdings     Holding[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([spaceId, type])
  @@index([ownerId])
  @@index([plaidItemDbId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FinancialAccount
// Canonical representation of a single real-world financial account.
// One row per real-world account — never duplicated.
// ownerType / ownerUserId / ownerSpaceId track who "owns" the account
// in the Fourth Meridian sense (not necessarily the legal bank account holder).
// Balance values here are always canonical — sourced from the isCanonical
// AccountConnection on each sync cycle.
// ─────────────────────────────────────────────────────────────────────────────

model FinancialAccount {
  id           String           @id @default(cuid())
  ownerType    AccountOwnerType
  ownerUserId  String?
  ownerUser    User?            @relation("UserOwnedFinancialAccounts", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerSpaceId String?
  ownerSpace   Space?           @relation("SpaceOwnedFinancialAccounts", fields: [ownerSpaceId], references: [id], onDelete: SetNull)

  // D11 (Phase 2 schema modernization): the human-accountable party independent
  // of the visibility owner. For ownerType=USER this is normally the same
  // person as ownerUserId; for ownerType=SPACE, ownerUserId is null by design
  // (visibility, not accountability), so this field is the only required
  // answer to "who connected this account on behalf of the Space." Additive,
  // nullable — backfilled from ownerUserId (falling back to the earliest
  // AccountConnection.connectedByUserId) for existing rows; set at creation
  // time for every new FinancialAccount going forward.
  createdByUserId String?
  createdByUser   User?   @relation("FinancialAccountCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Canonical values — written by the AccountConnection with isCanonical = true
  name                 String
  type                 AccountType
  institution          String
  institutionId        String? // Plaid institution_id (e.g. "ins_3")
  mask                 String? // last 4 digits of account number
  balance              Float       @default(0)
  availableBalance     Float?
  creditLimit          Float?
  currency             String      @default("USD")
  lastUpdated          DateTime    @default(now())
  // D4 Balance Freshness Provenance — the timestamp Plaid reported for when
  // the balance itself was last fetched from the institution. Distinct from
  // lastUpdated (which records when Fourth Meridian wrote to this row).
  // Populated from AccountBalance.last_updated_datetime on each Plaid refresh;
  // null for institutions that do not supply this field (currently most — Plaid
  // documents support only for ins_128026 / Capital One, but the field is typed
  // as optional on all AccountBalance responses). Never backfilled for existing
  // rows; null means "provenance unknown", not "balance is current".
  balanceLastUpdatedAt DateTime?

  // Plaid deduplication key
  plaidAccountId String? @unique

  // Display name metadata (additive — never overwritten by Plaid sync after creation).
  // Resolution order for what to show the user: displayName ?? officialName ?? plaidName ?? name.
  // `institution` (above) already serves as the human-readable institution name
  // (e.g. "Chase"), so no separate institutionName column was added.
  plaidName    String? // raw Plaid `name` value, captured once at import — never updated on resync
  officialName String? // Plaid `official_name`, captured once at import — never updated on resync
  displayName  String? // user-editable override; null until the user renames the account

  // Crypto self-custody fields
  walletAddress String?
  walletChain   String?
  nativeBalance Float?

  // Debt-specific fields (optional — populated for credit cards, loans, lines of credit)
  // Legacy flat fields — kept for backward compatibility with existing UI/queries.
  // New debt-profile data (APR, due date, statement close day, promo APR, notes)
  // lives on the DebtProfile relation below; effective values prefer DebtProfile
  // when present and fall back to these flat columns otherwise.
  debtSubtype    String? // e.g. credit_card, line_of_credit, heloc, auto_loan, mortgage, personal_loan, student_loan
  interestRate   Float? // Annual Percentage Rate (APR), e.g. 19.99
  minimumPayment Float? // Minimum monthly payment amount

  syncStatus String?   @default("pending")
  deletedAt  DateTime? // soft delete — preserves history

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connections              AccountConnection[]
  // SpaceAccountLink (D3) — the sole account-link path since WorkspaceAccountShare
  // was retired (v2.5-A Phase 4c).
  spaceAccountLinks        SpaceAccountLink[]
  duplicateCandidatesA     DuplicateAccountCandidate[] @relation("DuplicateCandidateA")
  duplicateCandidatesB     DuplicateAccountCandidate[] @relation("DuplicateCandidateB")
  goalContributions        GoalContribution[]
  debtProfile              DebtProfile?
  transactions             Transaction[]               @relation("FinancialAccountTransactions")
  holdings                 Holding[]
  // ProviderAccountIdentity (D2) — populated (Step 1C backfill + Step 2 dual-write).
  providerIdentities       ProviderAccountIdentity[]
  // ImportBatch (D2 Step 4D) — populated by the import pipeline.
  importBatches            ImportBatch[]
  // FlowType (v2.5.5 P3) — transactions whose counterparty ("other side") is
  // this account. Relation-only back-reference; populated from P4 onward.
  counterpartyTransactions Transaction[]               @relation("TransactionCounterpartyAccount")

  @@index([ownerUserId])
  @@index([ownerSpaceId])
  @@index([createdByUserId])
  @@index([type])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// DebtProfile
// Additive, optional 1:1 extension of FinancialAccount for debt details Plaid
// does not reliably provide (APR, minimum payment, due date, statement close
// day, promotional APR expiration). Kept as a separate model rather than more
// columns on FinancialAccount per the "dedicated debt profile" design — every
// field is nullable; creating this table does not touch any existing column.
// ─────────────────────────────────────────────────────────────────────────────

model DebtProfile {
  id                 String           @id @default(cuid())
  financialAccountId String           @unique
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  apr               Float? // user-entered APR, e.g. 24.99 — preferred over FinancialAccount.interestRate when set
  minimumPayment    Float? // user-entered minimum payment — preferred over FinancialAccount.minimumPayment when set
  dueDay            Int? // day of month payment is due (1-31)
  statementCloseDay Int? // day of month the statement closes (1-31)
  promoAprEndDate   DateTime? @db.Date // when a promotional/intro APR expires
  notes             String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financialAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AccountConnection
// Represents one user's connection to a FinancialAccount via a specific source
// (Plaid, manual entry, crypto wallet, etc.).
// isCanonical = true means this connection is the authoritative source for
// balance updates written back to FinancialAccount.
// Multiple connections to the same FinancialAccount are allowed (e.g. two
// spouses both have Plaid access to the same joint checking account).
// ─────────────────────────────────────────────────────────────────────────────

model AccountConnection {
  id                 String           @id @default(cuid())
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  connectedByUserId  String
  connectedByUser    User             @relation("UserConnectedAccounts", fields: [connectedByUserId], references: [id], onDelete: Cascade)

  // Source credentials — exactly one of plaidItemDbId or (walletAddress) will be set
  plaidItemDbId String?
  plaidItem     PlaidItem? @relation(fields: [plaidItemDbId], references: [id], onDelete: SetNull)

  // D2 — populated for PLAID by lib/plaid/exchangeToken.ts alongside
  // plaidItemDbId. Parallel path to plaidItemDbId for future non-Plaid
  // providers; existing Plaid/manual/wallet behavior unchanged.
  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  syncStatus   String    @default("pending")
  isCanonical  Boolean   @default(true) // authoritative balance source for this account
  lastSyncedAt DateTime?
  deletedAt    DateTime? // soft delete on account removal; preserves Holding/Transaction history

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financialAccountId])
  @@index([connectedByUserId])
  @@index([plaidItemDbId])
  @@index([connectionId])
  @@index([financialAccountId, isCanonical])
}

// WorkspaceAccountShare (retired v2.5-A Phase 4c) — model dropped after the D3
// SAL backfill + read cutover completed and the Phase 0 gates confirmed every
// WAS row was mirrored into SpaceAccountLink. A pre-drop pg_dump of the table
// is the recovery artifact (attached to the retirement PR); WAS rows are also
// 1:1 reconstructable from SAL kind=SHARED rows.

// ─────────────────────────────────────────────────────────────────────────────
// SpaceAccountLink (D3, Phase 2 → completed v2.5-A) — the sole account-link
// path: consolidates the retired WorkspaceAccountShare and FinancialAccount's
// ownerSpaceId/ownerUserId declared-owner pair into a single polymorphic link.
// kind=HOME replaces the declared-owner pair, kind=SHARED replaces the old
// WorkspaceAccountShare row. One row per (space, financialAccount) pair.
// A REVOKED link means the account is no longer visible to that space —
// typically triggered when the member who shared it is removed or leaves.
// See docs/initiatives/d3/D3_SPACE_ACCOUNT_LINK_REVIEW.md for the migration
// history and docs/investigations/V25A_PHASE0_SEAM_RETIREMENT_READINESS.md
// for the retirement gates.
// ─────────────────────────────────────────────────────────────────────────────
model SpaceAccountLink {
  id                 String               @id @default(cuid())
  spaceId            String
  space              Space                @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  financialAccountId String
  financialAccount   FinancialAccount     @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  kind               SpaceAccountLinkKind
  // OPS-2 S5 — nullable + SetNull (was required + Cascade). SAL doctrine is
  // revoke-don't-delete (status: REVOKED exists for exactly this); a hard
  // cascade on the adder's deletion would orphan accounts (including HOME
  // links) that other members rely on. The S7 pipeline revokes via status;
  // the FK then nulls harmlessly. Null addedByUserId = "adder's account no
  // longer exists" — the share-revoke route's self-check is null-safe (a
  // nulled adder simply requires OWNER/ADMIN to revoke).
  // See docs/initiatives/ops2/OPS2_S5_DELETION_INVENTORY.md.
  addedByUserId      String?
  addedByUser        User?                @relation("SpaceAccountLinkAdder", fields: [addedByUserId], references: [id], onDelete: SetNull)
  visibilityLevel    VisibilityLevel      @default(FULL)
  status             ShareStatus          @default(ACTIVE)
  revokedAt          DateTime?
  revokedByUserId    String?
  revokedByUser      User?                @relation("SpaceAccountLinkRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, financialAccountId])
  @@index([spaceId, status])
  @@index([financialAccountId, status])
  @@index([financialAccountId, kind])
  @@index([addedByUserId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DuplicateAccountCandidate
// Audit ledger of automatic duplicate-account merges performed by
// lib/accounts/reconcile.ts (mergeArchivedDuplicateIntoCanonical). Rows are
// written AFTER a merge has already happened — this table does not gate or
// block any merge, and nothing reads it back yet (no review UI exists).
// D1 (see docs/initiatives/d1/D1_DUPLICATE_ACCOUNT_CANDIDATE_DESIGN_REVIEW.md) repurposed
// this model from an unused human-review-queue design — the original comment
// here claimed "NEVER auto-merges," which was already false of the running
// code before D1 — into the audit ledger described above.
// ─────────────────────────────────────────────────────────────────────────────

model DuplicateAccountCandidate {
  id               String                   @id @default(cuid())
  // Nullable: mergeArchivedDuplicateIntoCanonical doesn't always have a space
  // in scope (the restore routes resolve by account ownership, not by Space).
  // A merge is a fact about an account pair, not inherently scoped to one
  // Space. Populated when the caller has a space in context (e.g. Plaid
  // import); null otherwise (e.g. the generic/manual restore routes).
  spaceId          String?
  // Directional by convention, not by name: accountA is always the
  // surviving canonical ("winner") row, accountB is always the archived row
  // whose history was folded into it ("loser"). See
  // mergeArchivedDuplicateIntoCanonical in lib/accounts/reconcile.ts.
  accountAId       String
  accountA         FinancialAccount         @relation("DuplicateCandidateA", fields: [accountAId], references: [id], onDelete: Cascade)
  accountBId       String
  accountB         FinancialAccount         @relation("DuplicateCandidateB", fields: [accountBId], references: [id], onDelete: Cascade)
  status           DuplicateStatus          @default(PENDING)
  detectionSource  DuplicateDetectionSource
  detectedAt       DateTime                 @default(now())
  // resolvedAt/resolvedByUserId predate D1 and still read as "a human
  // reviewed this." For every row written by the automatic merge path,
  // resolvedByUserId is null (no human in the loop) and resolvedAt is set to
  // the same instant as detectedAt — there is no review gap to measure.
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedByUser   User?                    @relation("DuplicateResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Kept as a true unique constraint, not relaxed to append-only: a later
  // re-merge of the same (winner, loser) pair (e.g. a second restore attempt
  // on an already-merged loser) upserts this row (bumping detectedAt)
  // instead of inserting a second one. See lib/accounts/reconcile.ts.
  @@unique([accountAId, accountBId])
  @@index([spaceId, status])
  @@index([accountAId])
  @@index([accountBId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceGoal (renamed from WorkspaceGoal)
// A financial goal belonging to a Space. Members contribute accounts to the
// goal via GoalContribution. Progress is computed from the sum of contributing
// account balances (or a subset of those balances).
// ─────────────────────────────────────────────────────────────────────────────

model SpaceGoal {
  id              String       @id @default(cuid())
  spaceId         String
  space           Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  // OPS-2 S5 — nullable + SetNull (was required + Cascade). A goal created in
  // a SHARED Space is the Space's data, not the creator's: deleting the
  // creator must never destroy other members' goals, contributions, or
  // check-ins. Null createdByUserId = "creator's account no longer exists".
  // See docs/initiatives/ops2/OPS2_S5_DELETION_INVENTORY.md.
  createdByUserId String?
  createdBy       User?        @relation("GoalCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  name            String
  description     String?
  category        GoalCategory @default(GENERAL)
  goalType        GoalType     @default(FINANCIAL)
  status          GoalStatus   @default(ACTIVE)

  // ── FINANCIAL fields ──────────────────────────────────────────────────────
  targetAmount  Float? // required for FINANCIAL & SPENDING_LIMIT
  currentAmount Float     @default(0) // denormalized — updated by sync job
  targetDate    DateTime? @db.Date

  // ── HABIT fields ──────────────────────────────────────────────────────────
  habitFrequency String? // DAILY | WEEKLY | MONTHLY
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastCheckIn    DateTime?

  // ── SPENDING_LIMIT fields ─────────────────────────────────────────────────
  spendingCategory String? // free-text category label

  // ── DEBT_REDUCTION fields ─────────────────────────────────────────────────
  linkedAccountId       String? // FK to FinancialAccount (soft ref — no cascade)
  targetReductionAmount Float? // pay down by $X
  targetReductionPct    Float? // pay down by X%
  snapshotBalance       Float? // balance at goal creation (for progress calc)

  completedAt DateTime?
  archivedAt  DateTime? // set when goal is archived
  deletedAt   DateTime? // soft delete — set when moved to trash

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contributions GoalContribution[]
  checkIns      GoalCheckIn[]

  @@index([spaceId, status])
  @@index([spaceId, category])
  @@index([spaceId, goalType])
}

// ─────────────────────────────────────────────────────────────────────────────
// GoalCheckIn
// Records each manual check-in for HABIT goals. Used for streak calculation.
// ─────────────────────────────────────────────────────────────────────────────

model GoalCheckIn {
  id        String    @id @default(cuid())
  goalId    String
  goal      SpaceGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  note      String?
  checkedAt DateTime  @default(now())

  @@index([goalId])
  @@index([goalId, checkedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// GoalContribution
// Links a FinancialAccount to a SpaceGoal. includeBalance controls whether
// the account's balance counts toward the goal's currentAmount.
// ─────────────────────────────────────────────────────────────────────────────

model GoalContribution {
  id                 String           @id @default(cuid())
  goalId             String
  goal               SpaceGoal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  includeBalance     Boolean          @default(true)

  createdAt DateTime @default(now())

  @@unique([goalId, financialAccountId])
  @@index([goalId])
  @@index([financialAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceDashboardSection (renamed from WorkspaceDashboardSection)
// Controls which sections/cards appear on the Space planning dashboard and
// in what order. Generated automatically from the Space category preset on
// Space creation. Members with OWNER/ADMIN role can toggle, reorder, or
// add custom sections.
// key: machine-readable identifier (e.g. "net_worth", "debt_payoff_tracker")
// label: display name shown in the UI (overrideable by user)
// tab: which dashboard tab this section appears under
// enabled: false hides the section without deleting it
// order: ascending sort order within the tab
// config: arbitrary JSON for section-specific settings (e.g. chart type, filters)
// ─────────────────────────────────────────────────────────────────────────────

model SpaceDashboardSection {
  id      String            @id @default(cuid())
  spaceId String
  space   Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  key     String // e.g. "net_worth", "goals_progress", "debt_payoff"
  label   String // display label
  tab     SpaceDashboardTab @default(OVERVIEW)
  enabled Boolean           @default(true)
  order   Int               @default(0)
  config  Json? // section-specific settings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, key])
  @@index([spaceId, tab])
  @@index([spaceId, enabled])
}

// ─────────────────────────────────────────────────────────────────────────────
// Holding
// One row per position (stock / ETF / crypto) per account.
//
// D11 (Phase 2 schema modernization): accountId (legacy Account FK) and
// financialAccountId (canonical FK) are both optional; exactly one is expected
// to be set per row — the same dual-FK pattern already used by Transaction
// (867–892 below). Legacy/seed-created rows keep accountId. Holdings synced
// for real Plaid-linked investment accounts (which only ever have a
// FinancialAccount, not a legacy Account) set financialAccountId instead.
// accountId was loosened from required to optional to allow this — no
// existing data is affected, every pre-existing row already has accountId set.
// Read-layer code (lib/data/accounts.ts getHoldings()) normalizes both back
// to a single accountId field on read, same as Transaction's pattern.
// ─────────────────────────────────────────────────────────────────────────────

model Holding {
  id        String   @id @default(cuid())
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  financialAccountId String?
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  symbol    String
  name      String
  quantity  Float
  price     Float
  value     Float
  change24h Float   @default(0)
  // Synthetic row written by sync job: account.balance − sum(real positions).
  isCash    Boolean @default(false)

  // MC1 Phase 0 — ISO 4217 code of `price` and `value` (the fiat valuation
  // unit — for crypto positions this is the quote currency, not the asset;
  // quantity stays unitless). Same null semantics as Transaction.currency.
  currency String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, symbol])
  @@unique([financialAccountId, symbol])
  @@index([accountId])
  @@index([accountId, isCash])
  @@index([financialAccountId])
  @@index([financialAccountId, isCash])
}

// ─────────────────────────────────────────────────────────────────────────────
// FlowType semantics (v2.5.5 Financial Intelligence — Transaction Semantics)
// Native enums promoted 1:1 from the P1 classifier's TypeScript unions
// (lib/transactions/flow-classifier.ts). Additive; Phase A adds the types and
// nullable columns only — no write-time population, backfill, or read cutover.
// See docs/initiatives/flowtype/P3_SCHEMA_DESIGN_INVESTIGATION.md.
// ─────────────────────────────────────────────────────────────────────────────

/// Economic KIND of a transaction (the canonical flow-semantics field).
enum FlowType {
  SPENDING
  INCOME
  REFUND
  DEBT_PAYMENT
  TRANSFER
  INVESTMENT
  FEE
  INTEREST
  ADJUSTMENT
  UNKNOWN
}

/// Economic DIRECTION, decoupled from the per-account amount sign.
enum FlowDirection {
  INFLOW
  OUTFLOW
  INTERNAL
  UNKNOWN
}

/// Stable, auditable reason a row received its flow classification.
enum FlowClassificationReason {
  PLAID_PFC_DETAILED
  PLAID_PFC_PRIMARY
  CATEGORY_FLOW_VALUE
  CATEGORY_INVESTMENT_VALUE
  ACCOUNT_TYPE_CONTEXT
  SIGN_DEFAULT_SPENDING
  SIGN_DEFAULT_INFLOW
  AMBIGUOUS_UNKNOWN
}

// ─────────────────────────────────────────────────────────────────────────────
// Transaction
// Pulled from Plaid or entered manually. Positive = money in, negative = out.
//
// accountId (legacy Account FK) and financialAccountId (canonical FK) are both
// optional; exactly one is expected to be set per row. Legacy/seed-created rows
// keep accountId. Transactions synced for real Plaid-linked accounts (which only
// ever have a FinancialAccount, not a legacy Account) set financialAccountId
// instead. accountId was loosened from required to optional to allow this —
// no existing data is affected, every pre-existing row already has accountId set.
// Data-layer code normalizes both back to a single accountId field on read.
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id        String   @id @default(cuid())
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  financialAccountId String?
  financialAccount   FinancialAccount? @relation("FinancialAccountTransactions", fields: [financialAccountId], references: [id], onDelete: Cascade)

  date        DateTime            @db.Date
  merchant    String
  description String?
  category    TransactionCategory
  amount      Float
  pending     Boolean             @default(false)

  plaidTransactionId String? @unique // prevents duplicate inserts on re-sync

  // D2 Step 4D — written by the import pipeline ("externalId" match
  // resolution in app/api/accounts/[id]/import). Generic sibling of plaidTransactionId
  // for files/exports that carry their own stable row id. Deliberately no
  // unique constraint yet — a CSV export's own id is only guaranteed unique
  // within that one file/institution, not globally; real uniqueness shape
  // (e.g. scoped to [financialAccountId, externalTransactionId]) is decided
  // at Step 4D implementation time, not assumed here. See
  // docs/initiatives/d2/investigations/D2_STEP4B_IMPORTBATCH_FOUNDATION_INVESTIGATION.md §3.
  importBatchId         String?
  importBatch           ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  externalTransactionId String?

  // D2 Step 4D-3 — soft-delete set by import rollback
  // (app/api/imports/[id]/rollback → ImportBatch.status = ROLLED_BACK).
  // See D2_STEP4B_IMPORTBATCH_FOUNDATION_INVESTIGATION.md §1.
  deletedAt DateTime?

  // ── FlowType semantics (v2.5.5 P3 Phase A — additive, nullable) ────────────
  // Persists the deterministic classifier output (lib/transactions/flow-classifier.ts).
  // Phase A only creates these columns; nothing writes or reads them yet
  // (write-time population = Phase B, backfill = P4, read cutover = P5).
  // counterpartyAccountId is the best-effort "other side" of the movement when
  // it is a known owned account — the destination-aware seam that makes
  // per-liability debt attribution (KD-18) deterministic. onDelete: SetNull
  // mirrors importBatchId: deleting the referenced account degrades the pointer
  // to null, never deletes the transaction.
  flowType                 FlowType?
  flowDirection            FlowDirection?
  counterpartyAccountId    String?
  counterpartyAccount      FinancialAccount?         @relation("TransactionCounterpartyAccount", fields: [counterpartyAccountId], references: [id], onDelete: SetNull)
  classificationConfidence Float?
  classificationReason     FlowClassificationReason?
  classifierVersion        Int?
  // Raw Plaid personal_finance_category hints (captured in memory since P2).
  // Kept as String — Plaid owns/versions this taxonomy; it is a provider hint,
  // not Fourth Meridian semantics (which live in flowType).
  pfcPrimary               String?
  pfcDetailed              String?
  pfcConfidenceLevel       String?
  // Forward seed for the Merchant Engine — the stable Plaid merchant key. Lets a
  // future Merchant table + merchantId FK backfill without a Plaid re-fetch.
  merchantEntityId         String?

  // MC1 Phase 0 — currency provenance (additive, nullable). ISO 4217 code of
  // `amount`, from Plaid iso_currency_code at write time, or the parent
  // account's currency for imports/fallback. Null = pre-Phase-0 row whose
  // denomination was never recorded (backfilled from parent account where
  // derivable). Nothing reads this until MC1 Phase 2+.
  currency String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([accountId, date])
  @@index([financialAccountId])
  @@index([financialAccountId, date])
  @@index([date])
  @@index([importBatchId])
  // FlowType rollup indexes (P3 Phase A): per-account/per-liability, global
  // per-flow lenses, and reverse counterparty attribution.
  @@index([financialAccountId, flowType, date])
  @@index([flowType, date])
  @@index([counterpartyAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ImportBatch (D2, Phase 2, Step 4B)
// One row per CSV/Excel/QuickBooks upload. Additive, schema-only — nothing
// reads or writes this table yet; the upload/parse/import pipeline is Step 4D.
// financialAccountId is required: the user always selects an existing target
// account before importing (no fingerprint-based auto-account-creation from
// file contents — see Step 4A §5). createdByUserId is nullable, mirroring
// FinancialAccount.createdByUserId's own D11 precedent, so that onDelete:
// SetNull is valid. connectionId is a forward-compatible seam mirroring
// AccountConnection.connectionId / ProviderAccountIdentity.connectionId —
// nullable, unpopulated until D2's later Adapter/ProviderCatalog work exists;
// ImportBatch does not depend on that work existing.
// See docs/initiatives/d2/investigations/D2_STEP4B_IMPORTBATCH_FOUNDATION_INVESTIGATION.md
// and docs/initiatives/d2/investigations/D2_STEP4A_IMPORT_HISTORY_FOUNDATION_INVESTIGATION.md.
// ─────────────────────────────────────────────────────────────────────────────

enum ImportSource {
  CSV
  EXCEL
  QUICKBOOKS
}

enum ImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  ROLLED_BACK
  FAILED
}

model ImportBatch {
  id String @id @default(cuid())

  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  // D2 Step 4D-5b — which ImportMappingProfile (if any) resolved this
  // batch's columns. Set only on the saved-profile-matched path; null for
  // the explicit-mapping and auto-detect paths. onDelete: SetNull so
  // deleting a profile later never deletes the historical batches that used
  // it. See docs/initiatives/d2/implementation/D2_STEP4D5B_IMPLEMENTATION_PLAN.md §2.
  mappingProfileId String?
  mappingProfile   ImportMappingProfile? @relation(fields: [mappingProfileId], references: [id], onDelete: SetNull)

  source                ImportSource
  originalFilename      String?
  status                ImportBatchStatus @default(PENDING)
  rowCount              Int               @default(0)
  importedCount         Int               @default(0)
  skippedCount          Int               @default(0)
  // D2 Step 4D-1 — additive counters needed once a real classifier (CSV
  // import) exists. matchedCount: rows that resolved to an already-existing
  // Transaction (no new row written) — distinct from skippedCount, which
  // covers rows skipped for other reasons (e.g. an ambiguous fingerprint
  // match). failedCount: rows that could not be parsed/validated at all. See
  // docs/initiatives/d2/investigations/D2_STEP4D1_CSV_IMPORT_MVP_INVESTIGATION.md §8.
  matchedCount          Int               @default(0)
  failedCount           Int               @default(0)
  errorSummary          Json?
  // D2 Step 4D-5b — snapshot of the actual resolved CsvColumnMap, written on
  // every import regardless of which resolver path produced it (auto-detect,
  // explicit mapping, or saved profile). Exists so a profile that's later
  // edited never retroactively changes what a historical batch is recorded
  // as having used — see D2_ARCHITECTURE_REVIEW_PRE_4D5B.md §2.
  resolvedColumnMapping Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  transactions Transaction[]

  @@index([financialAccountId])
  @@index([createdByUserId])
  @@index([connectionId])
  @@index([mappingProfileId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// ImportMappingProfile (D2, Phase 2, Step 4D-5b)
// Space-scoped, saved column mapping for recurring import sources (e.g. one
// specific bank's CSV/Excel export shape). `mapping` stores the *resolved*
// CsvColumnMap (lib/imports/csv.ts) — all 8 keys present, each a header
// string or null — produced by a prior successful applyExplicitMapping()
// call, not a caller's raw/partial input. Matching a profile against a new
// upload is a trial-application of that same mapping via
// applyExplicitMapping(), never a comparison of the file's full header set —
// see docs/initiatives/d2/investigations/D2_ARCHITECTURE_REVIEW_PRE_4D5B.md §5/§6 for why a
// header-signature hash was considered and rejected. source/institutionLabel
// are informational/display only, never consulted by the matcher. No CRUD
// route exists for this model yet (4D-5b is auto-use only, over rows seeded
// directly via the database client) — see
// docs/initiatives/d2/implementation/D2_STEP4D5B_IMPLEMENTATION_PLAN.md §7/§8.
// ─────────────────────────────────────────────────────────────────────────────

model ImportMappingProfile {
  id String @id @default(cuid())

  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  name             String
  source           ImportSource // informational only — NOT part of the matching key
  institutionLabel String? // informational only, e.g. "Chase"

  mapping Json // resolved CsvColumnMap shape — see module comment above

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  lastUsedAt DateTime?
  useCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importBatches ImportBatch[]

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([createdByUserId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceSnapshot (renamed from WorkspaceSnapshot, itself renamed from DailySnapshot)
// Written once per day by the background sync job.
// spaceId replaces userId — snapshots belong to the Space, not the user.
// ─────────────────────────────────────────────────────────────────────────────

model SpaceSnapshot {
  id      String   @id @default(cuid())
  spaceId String
  space   Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date

  // Portfolio breakdown
  stocks Float @default(0) // sum of investment account balances
  crypto Float @default(0) // sum of crypto account balances
  total  Float @default(0) // stocks + crypto

  // Banking breakdown
  cash    Float @default(0) // sum of checking balances
  savings Float @default(0) // sum of savings balances
  debt    Float @default(0) // absolute value of debt balances

  // Derived — pre-computed for fast chart queries
  netWorth    Float @default(0) // stocks + crypto + cash + savings − debt
  totalAssets Float @default(0) // stocks + crypto + cash + savings
  cashOnHand  Float @default(0) // max(cash − expense_buffer, 0) — renamed from cashToPlay (legacy "play cash" language)
  netLiquid   Float @default(0) // cash + savings − debt

  // D2.x Slice 4 — true for reconstructed/backfilled historical rows (cash
  // walked back from transactions; investments/loans/manual assets held flat).
  // Today's live snapshot and every pre-existing row read false. Additive,
  // defaulted → zero migration risk.
  isEstimated Boolean @default(false)

  // MC1 Phase 0 — the currency all ten totals on this row were computed and
  // presented in. NOT NULL DEFAULT "USD": unlike row-level stamps this is a
  // property of the computation, and every historical row was computed by
  // USD-presenting code, so the default is a true statement about old rows.
  reportingCurrency String @default("USD")

  createdAt DateTime @default(now())

  @@unique([spaceId, date])
  @@index([spaceId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// AiAdvice
// One record per advice engine run. Belongs to a Space and is attributed
// to the Space's AiAgent. userId removed — advice is Space-scoped.
// ─────────────────────────────────────────────────────────────────────────────

model AiAdvice {
  id          String    @id @default(cuid())
  spaceId     String
  space       Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  agentId     String
  agent       AiAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  summary     String
  adviceText  String    @db.Text
  riskLevel   RiskLevel
  actionReady Boolean   @default(false) // renamed from playReady (legacy "play cash" language)
  generatedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([spaceId, generatedAt])
  @@index([agentId, generatedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CreditScore
// Replaces User.ficoScore. Time-series: each manual or API update is a new
// row. source records where the score came from (app, bureau, manual).
// ─────────────────────────────────────────────────────────────────────────────

model CreditScore {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score      Int // 300–850
  source     String   @default("manual") // "manual" | "chase_app" | "amex_app" | "experian"
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog
// Append-only log of security-relevant events. NEVER cascade-deleted when a
// user or Space is removed — userId and spaceId are SET NULL instead.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id                 String   @id @default(cuid())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  spaceId            String?
  space              Space?   @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  action             String // See AuditAction constants in lib/audit-actions.ts
  metadata           Json? // e.g. { institution: "Chase", accountCount: 3 }
  ipAddress          String?
  userAgent          String?
  performedByAdminId String? // set when a SYSTEM_ADMIN performs an action on behalf of another user
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
  @@index([spaceId, createdAt])
  @@index([action, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// RecoveryCode
// One-time backup codes generated when a user enables or regenerates 2FA.
// Codes are shown once in plaintext, then stored as bcrypt hashes.
// Each code can be used once — usedAt is set on redemption.
// Regenerating codes invalidates all existing unused codes.
// ─────────────────────────────────────────────────────────────────────────────

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String // bcrypt hash (cost 10) of the plaintext code — NEVER stored as plaintext
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([userId])
  @@index([userId, usedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// UserSession
// Tracks active sessions for session management UI and admin revocation.
// Written on login. revokedAt is set when a session is force-terminated.
// Note: JWT sessions cannot be invalidated mid-token-lifetime without a
// blocklist or short-lived tokens. This table is informational for now;
// full revocation requires a token blocklist (see security limitations).
// ─────────────────────────────────────────────────────────────────────────────

model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String    @unique // random opaque identifier (not the JWT itself)
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime  @default(now())
  revokedAt    DateTime?
  revokedById  String? // admin userId who revoked this session
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([userId, revokedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PlatformSetting
// Key-value store for platform-wide security and feature toggles.
// Managed exclusively by SYSTEM_ADMIN via /admin/security.
// Keys are defined as constants in lib/platform-settings.ts.
// ─────────────────────────────────────────────────────────────────────────────

model PlatformSetting {
  key         String   @id // e.g. "require_totp_system_admin"
  value       String // "true" | "false" | numeric string
  updatedAt   DateTime @updatedAt
  updatedById String? // userId of last admin who changed this setting
}

// ─────────────────────────────────────────────────────────────────────────────
// RateLimit  (KD-3)
// Fixed-window request counter for endpoint-local rate limiting.
// One row per (key, windowStart) bucket; count is incremented per request.
// `key` encodes scope + endpoint + subject, e.g. "ip:pre-login:1.2.3.4" or
// "user:ai-chat:<userId>". Used only when RATE_LIMIT_ENABLED=true in
// production; local dev uses an in-memory backend (see lib/rate-limit.ts).
// Expired buckets can be swept lazily or via a future cron — additive only.
// ─────────────────────────────────────────────────────────────────────────────
model RateLimit {
  id          String   @id @default(cuid())
  key         String // scope:endpoint:subject
  windowStart DateTime // start of the fixed-window bucket
  count       Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([windowStart])
}

// ─────────────────────────────────────────────────────────────────────────────
// D2.x — Financial Data Integrity Gate (M1). Durable, queryable record of
// transaction-sync integrity issues so silent loss becomes visible and future
// Ambient Intelligence can reason over sync health. Forensic side-table — no
// other model references it; best-effort writes never affect sync results.
// ─────────────────────────────────────────────────────────────────────────────
model SyncIssue {
  id                 String        @id @default(cuid())
  provider           String        @default("PLAID")
  plaidItemId        String?
  financialAccountId String?
  kind               SyncIssueKind
  plaidTransactionId String?
  plaidAccountId     String?
  detail             Json? // { merchant, amount, date, balanceDelta, txnSum, threshold, ids, ... }
  resolved           Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([financialAccountId, resolved])
  @@index([plaidItemId, kind])
}

enum SyncIssueKind {
  MISSING_ACCOUNT
  UPSERT_ERROR
  REMOVED_TOMBSTONE
  BALANCE_TX_MISMATCH
  REPLAY_ATTEMPTED // reserved for v2.5 auto-recovery
  REPLAY_RECOVERED
  REPLAY_FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// FxRate (MC1 Phase 1) — immutable dated FX rate archive.
// Rows for closed dates are never updated or deleted (append-only, enforced at
// the application layer: insert-only writes for dates ≤ yesterday UTC). This
// immutability is what makes read-time conversion (MC1 Phase 2) deterministic
// and history-stable: resolving a past-dated rate returns the same answer
// forever. Standalone archive — no other model references it; nothing consumes
// it until MC1 Phase 2. See docs/initiatives/mc1/MC1_PHASE1_FX_PROVIDER_LAYER_PLAN.md.
// ─────────────────────────────────────────────────────────────────────────────
model FxRate {
  id        String   @id @default(cuid())
  date      DateTime @db.Date // valuation date, daily close granularity (plan D4)
  base      String            // canonical base — always "USD" (lib/fx/config.ts, Slice 2)
  quote     String            // ISO 4217
  rate      Float             // 1 base = rate quote (Float confirmed — plan D3)
  source    String            // adapter that supplied the batch — provenance
  fetchedAt DateTime @default(now())

  // Determinism anchor: ONE canonical rate per (date, pair) — deliberately not
  // per source; which provider supplied it is provenance (`source`), not identity.
  @@unique([date, base, quote])
  // Walk-back scans (base is constant USD): latest date ≤ asked, per quote.
  @@index([quote, date])
}
