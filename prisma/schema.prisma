generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // In production/staging (Supabase), set DATABASE_URL to the Transaction Pooler URL
  // (port 6543, ?pgbouncer=true) for Vercel serverless compatibility.
  // Set DIRECT_URL to the direct connection URL (port 5432) for migrations.
  // In local dev both can point to the same Docker Postgres URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum AccountType {
  checking
  savings
  investment
  crypto
  debt
  other
}

enum TransactionCategory {
  Income
  Transfer
  Groceries
  Dining
  Shopping
  Travel
  Subscriptions
  Utilities
  Interest
  Payment
  Other
  // Investment transactions
  Buy
  Sell
  Dividend
  Split
  Fee
}

enum RiskLevel {
  low
  medium
  high
}

enum PlaidItemStatus {
  ACTIVE        // syncing normally
  NEEDS_REAUTH  // user must re-authenticate via Plaid Link
  ERROR         // unrecoverable error — see errorCode
  REVOKED       // all accounts removed; itemRemove() was called
}

/// Renamed from Workspace -> Space (Fourth Meridian Phase 1 naming migration).
/// @@map keeps the underlying Postgres enum type name unchanged so this is a
/// code/Prisma-Client-only rename — no DDL required.
enum SpaceType {
  PERSONAL
  SHARED

  @@map("WorkspaceType")
}

/// Semantic category for a Space — drives default UI labels, section presets, and AI context.
/// Renamed from WorkspaceCategory -> SpaceCategory; @@map preserves the DB type name.
enum SpaceCategory {
  PERSONAL
  HOUSEHOLD
  FAMILY
  BUSINESS
  PROPERTY
  VEHICLE
  TRIP
  INVESTMENT
  EQUIPMENT
  GOAL          // legacy — kept for backward compat
  RETIREMENT
  DEBT_PAYOFF
  EMERGENCY_FUND
  CUSTOM
  OTHER

  @@map("WorkspaceCategory")
}

/// Tabs available on the Space planning dashboard.
/// Each SpaceDashboardSection belongs to one tab.
/// Renamed from WorkspaceDashboardTab -> SpaceDashboardTab; @@map preserves the DB type name.
enum SpaceDashboardTab {
  OVERVIEW
  GOALS
  ACCOUNTS
  DEBT
  INVESTMENTS
  RETIREMENT
  ACTIVITY
  SETTINGS

  @@map("WorkspaceDashboardTab")
}

/// Renamed from WorkspaceMemberRole -> SpaceMemberRole; @@map preserves the DB type name.
enum SpaceMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER

  @@map("WorkspaceMemberRole")
}

/// Soft-membership state. REMOVED = kicked by OWNER/ADMIN. LEFT = self-removed.
/// Row is never deleted so audit history is preserved.
/// Renamed from WorkspaceMemberStatus -> SpaceMemberStatus; @@map preserves the DB type name.
enum SpaceMemberStatus {
  ACTIVE
  REMOVED
  LEFT

  @@map("WorkspaceMemberStatus")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

/// Controls how a FinancialAccount is visible to a Space it has been shared into.
/// BALANCE_ONLY added for privacy-sensitive sharing (e.g. a partner sees total but not institution).
/// FULL replaces the old SHARED value; SHARED kept temporarily for Account (legacy) rows.
enum VisibilityLevel {
  PRIVATE       // only the owning Space can see this account
  BALANCE_ONLY  // other Space sees the balance total, no institution or transactions
  SUMMARY_ONLY  // qualitative summary, no raw numbers
  SHARED        // legacy — maps to FULL; kept for backward compat with Account model
  FULL          // fully visible to all Space members (new canonical value)
}

/// Whether a WorkspaceAccountShare is currently active or has been revoked.
enum ShareStatus {
  ACTIVE
  REVOKED
}

/// Lifecycle of a suspected duplicate pair surfaced by the system.
/// CONFIRMED_DUPLICATE is written automatically today by the merge path in
/// lib/accounts/reconcile.ts (mergeArchivedDuplicateIntoCanonical) — there is
/// no gate that blocks a merge pending review. PENDING / NOT_DUPLICATE /
/// IGNORED are not written by any code path today; they're kept, unused, in
/// case a future manual-review feature is layered on top of this ledger.
enum DuplicateStatus {
  PENDING              // flagged, awaiting user review
  CONFIRMED_DUPLICATE  // user confirmed these are the same real-world account
  NOT_DUPLICATE        // user confirmed these are different accounts
  IGNORED              // user dismissed without deciding
}

/// How an automatic merge in lib/accounts/reconcile.ts was detected. Always
/// populated on rows written by that path — there is no ambiguous/unset case
/// today.
enum DuplicateDetectionSource {
  PROVIDER_IDENTITY_MATCH  // exact plaidAccountId or walletAddress match
  FINGERPRINT_MATCH        // loose institution + mask + type + name match
  SIBLING_CONSOLIDATION    // multiple matching rows reduced to one canonical row, independent of the top-level trigger
}

/// Whether a FinancialAccount is owned by an individual user or by a Space entity.
/// SPACE was renamed from WORKSPACE in the Fourth Meridian Phase 1 naming migration —
/// this is a real `ALTER TYPE ... RENAME VALUE` migration (see
/// prisma/migrations/*_rename_account_owner_type_workspace_to_space/), not a @map,
/// because the existing label is genuinely renamed end-to-end. The rename is
/// metadata-only in Postgres: existing rows keep referencing the same enum OID,
/// so no row data is rewritten and no UPDATE statement is needed.
enum AccountOwnerType {
  USER   // personal account owned by a single user
  SPACE  // Space-level account (e.g. a joint or business account)
}

enum UserRole {
  USER          // normal authenticated user
  SYSTEM_ADMIN  // platform administration — not for daily use; requires TOTP (M3)
}

enum EmploymentStatus {
  EMPLOYED
  UNEMPLOYED
  SELF_EMPLOYED
  STUDENT
  RETIRED
}

enum UseCase {
  PERSONAL_TRACKING   // personal budget + net worth tracking
  BUSINESS_VENTURES   // business / LLC financial oversight
  INVESTING           // portfolio + market focus
  DEBT_MANAGEMENT     // debt payoff planning
  OTHER
}

/// Category of a financial goal — drives default labels and AI context.
enum GoalCategory {
  EMERGENCY_FUND
  DEBT_PAYOFF
  HOME_PURCHASE
  VEHICLE_PURCHASE
  TRIP
  BUSINESS
  INVESTMENT
  EQUIPMENT
  EDUCATION
  GENERAL
}

/// Lifecycle state of a SpaceGoal.
enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

/// Governs which fields and tracking mode apply to a SpaceGoal.
enum GoalType {
  FINANCIAL       // Save $X by a target date
  HABIT           // Behavioral goal tracked by streak / check-ins
  SPENDING_LIMIT  // Keep a spending category under $X / month
  DEBT_REDUCTION  // Pay down a specific debt account by $X or X%
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ficoScore removed — now lives in CreditScore for time-series tracking.
// Profile fields (DOB, employment, useCase) feed the AI advice engine.
// dateOfBirthEncrypted is AES-256-GCM (same key as Plaid tokens).
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  username             String?           @unique
  name                 String?
  firstName            String?
  lastName             String?
  dateOfBirthEncrypted String?           // AES-256-GCM encrypted ISO date string
  employmentStatus     EmploymentStatus?
  useCase              UseCase?
  passwordHash         String?           // bcrypt hash, cost 12
  totpSecret           String?           // TOTP seed, stored encrypted (used in M3)
  totpEnabled          Boolean           @default(false)
  role                 UserRole          @default(USER)
  preferredSpaceId     String?           @map("preferredWorkspaceId") // soft ref — Space the user lands on after login
  passwordResetToken   String?           @unique
  passwordResetExpiry  DateTime?
  forcePasswordReset   Boolean           @default(false) // set true by admin; user must change on next login
  lastBriefViewedAt    DateTime?                         // set when user views the Daily Brief page
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  spaces               SpaceMember[]
  sentInvites          SpaceInvite[]     @relation("SentInvites")
  receivedInvites      SpaceInvite[]     @relation("ReceivedInvites")
  plaidItems           PlaidItem[]
  ownedAccounts        Account[]         // legacy: accounts this user connected/created
  creditScores         CreditScore[]
  auditLogs            AuditLog[]

  // Security
  recoveryCodes        RecoveryCode[]
  sessions             UserSession[]

  // New financial account relations
  financialAccounts    FinancialAccount[]  @relation("UserOwnedFinancialAccounts")
  accountConnections   AccountConnection[] @relation("UserConnectedAccounts")
  createdFinancialAccounts FinancialAccount[] @relation("FinancialAccountCreator") // D11 — accounts this user created/connected, independent of ownerType

  // Member revocation (who revoked whom)
  revokedMembers       SpaceMember[]       @relation("RevokedByUser")

  // Goal creation
  createdGoals         SpaceGoal[]         @relation("GoalCreator")

  // WorkspaceAccountShare — excluded from the Phase 1 Workspace->Space rename; this
  // model has its own future replacement (SpaceAccountLink, Phase 3) with different
  // semantics, so it deliberately keeps its current name and field/relation names
  // here for now. Tracks who added/revoked shares.
  addedShares          WorkspaceAccountShare[] @relation("ShareAdder")
  revokedShares        WorkspaceAccountShare[] @relation("ShareRevoker")

  // DuplicateAccountCandidate — tracks who resolved the review
  resolvedDuplicates   DuplicateAccountCandidate[] @relation("DuplicateResolver")
}

// ─────────────────────────────────────────────────────────────────────────────
// Space (renamed from Workspace — Fourth Meridian Phase 1 naming migration)
// Container for all financial data. Every user auto-receives one PERSONAL
// Space on registration. Additional SHARED Spaces can be created or
// joined (Hogan Family, Atlanta Duplex LLC, etc.)
// category provides semantic context for the Space (e.g. HOUSEHOLD, BUSINESS).
// @@map keeps the underlying "Workspace" table name unchanged — this is a
// Prisma-Client-only rename, no DDL required.
// ─────────────────────────────────────────────────────────────────────────────

model Space {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        SpaceType     @default(PERSONAL)
  category    SpaceCategory @default(PERSONAL)
  isPublic    Boolean       @default(false)  // SHARED Spaces can be listed publicly

  // ── Lifecycle (mirrors SpaceGoal's archive/trash pattern) ─────────────────
  // archivedAt: hidden from normal nav, fully intact, restorable any time.
  // deletedAt:  moved to trash, hidden from normal nav, restorable until
  //             permanently deleted. Trashing always clears archivedAt so a
  //             Space is never in both states at once. PERSONAL
  //             Spaces cannot be archived, trashed, or permanently
  //             deleted (enforced in the API layer, not the schema).
  archivedAt  DateTime?
  deletedAt   DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members       SpaceMember[]
  invites       SpaceInvite[]
  accounts      Account[]       // legacy account relation
  snapshots     SpaceSnapshot[]
  aiAgent       AiAgent?
  adviceHistory AiAdvice[]
  auditLogs     AuditLog[]

  // New financial account relations
  // accountShares — excluded from this rename; still points at WorkspaceAccountShare
  // (Phase 3 will replace it with SpaceAccountLink). The field name itself never
  // contained "workspace" so it's unaffected either way.
  accountShares         WorkspaceAccountShare[]
  ownedFinancialAccounts FinancialAccount[]      @relation("SpaceOwnedFinancialAccounts")
  goals                  SpaceGoal[]
  dashboardSections      SpaceDashboardSection[]

  @@index([type])
  @@index([isPublic])
  @@index([archivedAt])
  @@index([deletedAt])
  @@map("Workspace")
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceMember (renamed from WorkspaceMember)
// Join table linking users to Spaces with roles.
// status: ACTIVE (normal), REMOVED (kicked), LEFT (self-removed).
// Rows are never deleted — status update preserves audit history.
// When status becomes REMOVED or LEFT, all WorkspaceAccountShare records
// contributed by that user are revoked.
// ─────────────────────────────────────────────────────────────────────────────

model SpaceMember {
  id       String           @id @default(cuid())
  spaceId  String           @map("workspaceId")
  space    Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     SpaceMemberRole  @default(MEMBER)
  status   SpaceMemberStatus @default(ACTIVE)
  joinedAt DateTime         @default(now())

  // Populated when status transitions to REMOVED or LEFT
  revokedAt   DateTime?
  revokedById String?
  revokedBy   User?         @relation("RevokedByUser", fields: [revokedById], references: [id], onDelete: SetNull)

  @@unique([spaceId, userId])
  @@index([spaceId])
  @@index([userId])
  @@index([spaceId, status])
  @@map("WorkspaceMember")
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceInvite (renamed from WorkspaceInvite)
// Grant-only access. Only existing members with OWNER or ADMIN role can invite.
// Users cannot request access — they can only accept or decline an invite.
// ─────────────────────────────────────────────────────────────────────────────

model SpaceInvite {
  id            String          @id @default(cuid())
  spaceId       String          @map("workspaceId")
  space         Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  invitedById   String
  invitedBy     User            @relation("SentInvites",     fields: [invitedById],   references: [id], onDelete: Cascade)
  invitedUserId String
  invitedUser   User            @relation("ReceivedInvites", fields: [invitedUserId], references: [id], onDelete: Cascade)
  role          SpaceMemberRole @default(MEMBER)
  status        InviteStatus    @default(PENDING)
  createdAt     DateTime        @default(now())
  expiresAt     DateTime?
  seenAt        DateTime?       // set when invited user first views the invite

  @@unique([spaceId, invitedUserId])
  @@index([invitedUserId])
  @@index([spaceId])
  @@map("WorkspaceInvite")
}

// ─────────────────────────────────────────────────────────────────────────────
// AiAgent
// One agent per Space. Owns all advice and (future) memory for that
// Space. Created automatically when a Space is created.
// ─────────────────────────────────────────────────────────────────────────────

model AiAgent {
  id           String    @id @default(cuid())
  spaceId      String    @unique @map("workspaceId")
  space        Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name         String
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  adviceHistory AiAdvice[]

  @@index([spaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PlaidItem
// Stays on User — it is a credential (OAuth token), not a Space asset.
// One item per institution; a single token covers all accounts at that bank.
// Accounts derived from this item are created as FinancialAccount rows.
// ─────────────────────────────────────────────────────────────────────────────

model PlaidItem {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalItemId  String          @unique  // provider's item/connection id (Plaid item_id today)
  institutionId   String                   // Plaid's institution_id (e.g. "ins_3")
  institutionName String                   // human-readable (e.g. "Chase")
  encryptedToken  String                   // AES-256-GCM encrypted access token — NEVER plaintext
  status          PlaidItemStatus @default(ACTIVE)
  cursor          String?                  // /transactions/sync cursor for incremental sync
  errorCode       String?                  // last Plaid error code when status = ERROR
  lastSyncedAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  accounts    Account[]           // legacy relation
  connections AccountConnection[] // new relation

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Account (LEGACY — kept temporarily during migration)
// Will be removed once all data is migrated to FinancialAccount +
// AccountConnection + WorkspaceAccountShare and validated in production.
// Do not add new features here; use FinancialAccount instead.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id               String          @id @default(cuid())
  spaceId          String          @map("workspaceId")
  space            Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  ownerId          String?                          // who connected this account; nullable (SetNull on user delete)
  owner            User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  visibilityLevel  VisibilityLevel @default(PRIVATE)
  name             String
  type             AccountType
  institution      String
  balance          Float           @default(0)      // current/ledger balance
  availableBalance Float?                           // Plaid: balance after pending transactions clear
  creditLimit      Float?                           // credit cards: limit from Plaid or manual entry
  currency         String          @default("USD")
  lastUpdated      DateTime        @default(now())
  deletedAt        DateTime?                        // soft delete — hides from UI, preserves history

  // Plaid — token lives on PlaidItem, not here
  plaidAccountId String? @unique                   // Plaid's account_id for this specific account
  plaidItemDbId  String?                           // FK → PlaidItem.id (our internal id)
  plaidItem      PlaidItem? @relation(fields: [plaidItemDbId], references: [id])

  // Crypto self-custody fields (wallet address accounts only)
  walletAddress String?
  walletChain   String?
  nativeBalance Float?
  syncStatus    String? @default("pending")

  holdings     Holding[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([spaceId, type])
  @@index([ownerId])
  @@index([plaidItemDbId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FinancialAccount
// Canonical representation of a single real-world financial account.
// One row per real-world account — never duplicated.
// ownerType / ownerUserId / ownerSpaceId track who "owns" the account
// in the Fourth Meridian sense (not necessarily the legal bank account holder).
// Balance values here are always canonical — sourced from the isCanonical
// AccountConnection on each sync cycle.
// ─────────────────────────────────────────────────────────────────────────────

model FinancialAccount {
  id               String           @id @default(cuid())
  ownerType        AccountOwnerType
  ownerUserId      String?
  ownerUser        User?            @relation("UserOwnedFinancialAccounts", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerSpaceId     String?          @map("ownerWorkspaceId")
  ownerSpace       Space?           @relation("SpaceOwnedFinancialAccounts", fields: [ownerSpaceId], references: [id], onDelete: SetNull)

  // D11 (Phase 2 schema modernization): the human-accountable party independent
  // of the visibility owner. For ownerType=USER this is normally the same
  // person as ownerUserId; for ownerType=SPACE, ownerUserId is null by design
  // (visibility, not accountability), so this field is the only required
  // answer to "who connected this account on behalf of the Space." Additive,
  // nullable — backfilled from ownerUserId (falling back to the earliest
  // AccountConnection.connectedByUserId) for existing rows; set at creation
  // time for every new FinancialAccount going forward.
  createdByUserId  String?
  createdByUser    User?            @relation("FinancialAccountCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Canonical values — written by the AccountConnection with isCanonical = true
  name             String
  type             AccountType
  institution      String
  institutionId    String?          // Plaid institution_id (e.g. "ins_3")
  mask             String?          // last 4 digits of account number
  balance          Float            @default(0)
  availableBalance Float?
  creditLimit      Float?
  currency         String           @default("USD")
  lastUpdated      DateTime         @default(now())

  // Plaid deduplication key
  plaidAccountId   String?          @unique

  // Display name metadata (additive — never overwritten by Plaid sync after creation).
  // Resolution order for what to show the user: displayName ?? officialName ?? plaidName ?? name.
  // `institution` (above) already serves as the human-readable institution name
  // (e.g. "Chase"), so no separate institutionName column was added.
  plaidName        String?          // raw Plaid `name` value, captured once at import — never updated on resync
  officialName     String?          // Plaid `official_name`, captured once at import — never updated on resync
  displayName      String?          // user-editable override; null until the user renames the account

  // Crypto self-custody fields
  walletAddress    String?
  walletChain      String?
  nativeBalance    Float?

  // Debt-specific fields (optional — populated for credit cards, loans, lines of credit)
  // Legacy flat fields — kept for backward compatibility with existing UI/queries.
  // New debt-profile data (APR, due date, statement close day, promo APR, notes)
  // lives on the DebtProfile relation below; effective values prefer DebtProfile
  // when present and fall back to these flat columns otherwise.
  debtSubtype      String?          // e.g. credit_card, line_of_credit, heloc, auto_loan, mortgage, personal_loan, student_loan
  interestRate     Float?           // Annual Percentage Rate (APR), e.g. 19.99
  minimumPayment   Float?           // Minimum monthly payment amount

  syncStatus       String?          @default("pending")
  deletedAt        DateTime?        // soft delete — preserves history

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  connections           AccountConnection[]
  // workspaceShares — excluded from the Phase 1 Workspace->Space rename; this
  // field and the WorkspaceAccountShare model it points to have a separate
  // future replacement (SpaceAccountLink, Phase 3) with different semantics,
  // so the name deliberately stays as-is for now.
  workspaceShares       WorkspaceAccountShare[]
  duplicateCandidatesA  DuplicateAccountCandidate[] @relation("DuplicateCandidateA")
  duplicateCandidatesB  DuplicateAccountCandidate[] @relation("DuplicateCandidateB")
  goalContributions     GoalContribution[]
  debtProfile           DebtProfile?
  transactions          Transaction[]               @relation("FinancialAccountTransactions")
  holdings              Holding[]

  @@index([ownerUserId])
  @@index([ownerSpaceId])
  @@index([createdByUserId])
  @@index([type])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// DebtProfile
// Additive, optional 1:1 extension of FinancialAccount for debt details Plaid
// does not reliably provide (APR, minimum payment, due date, statement close
// day, promotional APR expiration). Kept as a separate model rather than more
// columns on FinancialAccount per the "dedicated debt profile" design — every
// field is nullable; creating this table does not touch any existing column.
// ─────────────────────────────────────────────────────────────────────────────

model DebtProfile {
  id                 String           @id @default(cuid())
  financialAccountId String           @unique
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  apr               Float?           // user-entered APR, e.g. 24.99 — preferred over FinancialAccount.interestRate when set
  minimumPayment    Float?           // user-entered minimum payment — preferred over FinancialAccount.minimumPayment when set
  dueDay            Int?             // day of month payment is due (1-31)
  statementCloseDay Int?             // day of month the statement closes (1-31)
  promoAprEndDate   DateTime?        @db.Date // when a promotional/intro APR expires
  notes             String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financialAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AccountConnection
// Represents one user's connection to a FinancialAccount via a specific source
// (Plaid, manual entry, crypto wallet, etc.).
// isCanonical = true means this connection is the authoritative source for
// balance updates written back to FinancialAccount.
// Multiple connections to the same FinancialAccount are allowed (e.g. two
// spouses both have Plaid access to the same joint checking account).
// ─────────────────────────────────────────────────────────────────────────────

model AccountConnection {
  id                 String           @id @default(cuid())
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  connectedByUserId  String
  connectedByUser    User             @relation("UserConnectedAccounts", fields: [connectedByUserId], references: [id], onDelete: Cascade)

  // Source credentials — exactly one of plaidItemDbId or (walletAddress) will be set
  plaidItemDbId      String?
  plaidItem          PlaidItem?       @relation(fields: [plaidItemDbId], references: [id], onDelete: SetNull)

  syncStatus         String           @default("pending")
  isCanonical        Boolean          @default(true)   // authoritative balance source for this account
  lastSyncedAt       DateTime?
  deletedAt          DateTime?        // soft delete on account removal; preserves Holding/Transaction history

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([financialAccountId])
  @@index([connectedByUserId])
  @@index([plaidItemDbId])
  @@index([financialAccountId, isCanonical])
}

// ─────────────────────────────────────────────────────────────────────────────
// WorkspaceAccountShare
// Controls which workspaces can see a FinancialAccount and at what fidelity.
// One row per (workspace, financialAccount) pair.
// A REVOKED share means the account is no longer visible to that workspace —
// typically triggered when the member who shared it is removed or leaves.
// ─────────────────────────────────────────────────────────────────────────────

// NOTE: WorkspaceAccountShare is deliberately excluded from the Fourth Meridian
// Phase 1 Workspace->Space rename — it has its own future replacement
// (SpaceAccountLink, Phase 3) with different semantics, so its model name,
// field names (workspaceId/workspace), and Prisma Client accessor all stay
// exactly as they are. The `workspace` relation field's TYPE annotation below
// is updated to `Space` purely because the `Workspace` model name no longer
// exists — this is a mechanical necessity, not a scope change.
model WorkspaceAccountShare {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          Space            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  addedByUserId      String
  addedByUser        User             @relation("ShareAdder", fields: [addedByUserId], references: [id], onDelete: Cascade)
  visibilityLevel    VisibilityLevel  @default(FULL)
  status             ShareStatus      @default(ACTIVE)
  revokedAt          DateTime?
  revokedByUserId    String?
  revokedByUser      User?            @relation("ShareRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([workspaceId, financialAccountId])
  @@index([workspaceId, status])
  @@index([financialAccountId, status])
  @@index([addedByUserId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DuplicateAccountCandidate
// Audit ledger of automatic duplicate-account merges performed by
// lib/accounts/reconcile.ts (mergeArchivedDuplicateIntoCanonical). Rows are
// written AFTER a merge has already happened — this table does not gate or
// block any merge, and nothing reads it back yet (no review UI exists).
// D1 (see docs/D1_DUPLICATE_ACCOUNT_CANDIDATE_DESIGN_REVIEW.md) repurposed
// this model from an unused human-review-queue design — the original comment
// here claimed "NEVER auto-merges," which was already false of the running
// code before D1 — into the audit ledger described above.
// ─────────────────────────────────────────────────────────────────────────────

model DuplicateAccountCandidate {
  id                String                    @id @default(cuid())
  // Nullable: mergeArchivedDuplicateIntoCanonical doesn't always have a space
  // in scope (the restore routes resolve by account ownership, not by Space).
  // A merge is a fact about an account pair, not inherently scoped to one
  // Space. Populated when the caller has a space in context (e.g. Plaid
  // import); null otherwise (e.g. the generic/manual restore routes).
  spaceId           String?                   @map("workspaceId")
  // Directional by convention, not by name: accountA is always the
  // surviving canonical ("winner") row, accountB is always the archived row
  // whose history was folded into it ("loser"). See
  // mergeArchivedDuplicateIntoCanonical in lib/accounts/reconcile.ts.
  accountAId        String
  accountA          FinancialAccount          @relation("DuplicateCandidateA", fields: [accountAId], references: [id], onDelete: Cascade)
  accountBId        String
  accountB          FinancialAccount          @relation("DuplicateCandidateB", fields: [accountBId], references: [id], onDelete: Cascade)
  status            DuplicateStatus           @default(PENDING)
  detectionSource   DuplicateDetectionSource
  detectedAt        DateTime                  @default(now())
  // resolvedAt/resolvedByUserId predate D1 and still read as "a human
  // reviewed this." For every row written by the automatic merge path,
  // resolvedByUserId is null (no human in the loop) and resolvedAt is set to
  // the same instant as detectedAt — there is no review gap to measure.
  resolvedAt        DateTime?
  resolvedByUserId  String?
  resolvedByUser    User?                     @relation("DuplicateResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt         DateTime                  @default(now())

  // Kept as a true unique constraint, not relaxed to append-only: a later
  // re-merge of the same (winner, loser) pair (e.g. a second restore attempt
  // on an already-merged loser) upserts this row (bumping detectedAt)
  // instead of inserting a second one. See lib/accounts/reconcile.ts.
  @@unique([accountAId, accountBId])
  @@index([spaceId, status])
  @@index([accountAId])
  @@index([accountBId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceGoal (renamed from WorkspaceGoal)
// A financial goal belonging to a Space. Members contribute accounts to the
// goal via GoalContribution. Progress is computed from the sum of contributing
// account balances (or a subset of those balances).
// ─────────────────────────────────────────────────────────────────────────────

model SpaceGoal {
  id              String        @id @default(cuid())
  spaceId         String        @map("workspaceId")
  space           Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User          @relation("GoalCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  category        GoalCategory  @default(GENERAL)
  goalType        GoalType      @default(FINANCIAL)
  status          GoalStatus    @default(ACTIVE)

  // ── FINANCIAL fields ──────────────────────────────────────────────────────
  targetAmount    Float?                          // required for FINANCIAL & SPENDING_LIMIT
  currentAmount   Float         @default(0)       // denormalized — updated by sync job
  targetDate      DateTime?     @db.Date

  // ── HABIT fields ──────────────────────────────────────────────────────────
  habitFrequency  String?                         // DAILY | WEEKLY | MONTHLY
  currentStreak   Int           @default(0)
  longestStreak   Int           @default(0)
  lastCheckIn     DateTime?

  // ── SPENDING_LIMIT fields ─────────────────────────────────────────────────
  spendingCategory String?                        // free-text category label

  // ── DEBT_REDUCTION fields ─────────────────────────────────────────────────
  linkedAccountId       String?                   // FK to FinancialAccount (soft ref — no cascade)
  targetReductionAmount Float?                    // pay down by $X
  targetReductionPct    Float?                    // pay down by X%
  snapshotBalance       Float?                    // balance at goal creation (for progress calc)

  completedAt     DateTime?
  archivedAt      DateTime?                     // set when goal is archived
  deletedAt       DateTime?                     // soft delete — set when moved to trash

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  contributions   GoalContribution[]
  checkIns        GoalCheckIn[]

  @@index([spaceId, status])
  @@index([spaceId, category])
  @@index([spaceId, goalType])
  @@map("WorkspaceGoal")
}

// ─────────────────────────────────────────────────────────────────────────────
// GoalCheckIn
// Records each manual check-in for HABIT goals. Used for streak calculation.
// ─────────────────────────────────────────────────────────────────────────────

model GoalCheckIn {
  id        String    @id @default(cuid())
  goalId    String
  goal      SpaceGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  note      String?
  checkedAt DateTime  @default(now())

  @@index([goalId])
  @@index([goalId, checkedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// GoalContribution
// Links a FinancialAccount to a SpaceGoal. includeBalance controls whether
// the account's balance counts toward the goal's currentAmount.
// ─────────────────────────────────────────────────────────────────────────────

model GoalContribution {
  id                 String           @id @default(cuid())
  goalId             String
  goal               SpaceGoal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  includeBalance     Boolean          @default(true)

  createdAt          DateTime         @default(now())

  @@unique([goalId, financialAccountId])
  @@index([goalId])
  @@index([financialAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceDashboardSection (renamed from WorkspaceDashboardSection)
// Controls which sections/cards appear on the Space planning dashboard and
// in what order. Generated automatically from the Space category preset on
// Space creation. Members with OWNER/ADMIN role can toggle, reorder, or
// add custom sections.
// key: machine-readable identifier (e.g. "net_worth", "debt_payoff_tracker")
// label: display name shown in the UI (overrideable by user)
// tab: which dashboard tab this section appears under
// enabled: false hides the section without deleting it
// order: ascending sort order within the tab
// config: arbitrary JSON for section-specific settings (e.g. chart type, filters)
// ─────────────────────────────────────────────────────────────────────────────

model SpaceDashboardSection {
  id        String             @id @default(cuid())
  spaceId   String             @map("workspaceId")
  space     Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  key       String             // e.g. "net_worth", "goals_progress", "debt_payoff"
  label     String             // display label
  tab       SpaceDashboardTab  @default(OVERVIEW)
  enabled   Boolean            @default(true)
  order     Int                @default(0)
  config    Json?              // section-specific settings

  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([spaceId, key])
  @@index([spaceId, tab])
  @@index([spaceId, enabled])
  @@map("WorkspaceDashboardSection")
}

// ─────────────────────────────────────────────────────────────────────────────
// Holding
// One row per position (stock / ETF / crypto) per account.
//
// D11 (Phase 2 schema modernization): accountId (legacy Account FK) and
// financialAccountId (canonical FK) are both optional; exactly one is expected
// to be set per row — the same dual-FK pattern already used by Transaction
// (867–892 below). Legacy/seed-created rows keep accountId. Holdings synced
// for real Plaid-linked investment accounts (which only ever have a
// FinancialAccount, not a legacy Account) set financialAccountId instead.
// accountId was loosened from required to optional to allow this — no
// existing data is affected, every pre-existing row already has accountId set.
// Read-layer code (lib/data/accounts.ts getHoldings()) normalizes both back
// to a single accountId field on read, same as Transaction's pattern.
// ─────────────────────────────────────────────────────────────────────────────

model Holding {
  id        String   @id @default(cuid())
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  financialAccountId String?
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  symbol    String
  name      String
  quantity  Float
  price     Float
  value     Float
  change24h Float   @default(0)
  // Synthetic row written by sync job: account.balance − sum(real positions).
  isCash    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, symbol])
  @@unique([financialAccountId, symbol])
  @@index([accountId])
  @@index([accountId, isCash])
  @@index([financialAccountId])
  @@index([financialAccountId, isCash])
}

// ─────────────────────────────────────────────────────────────────────────────
// Transaction
// Pulled from Plaid or entered manually. Positive = money in, negative = out.
//
// accountId (legacy Account FK) and financialAccountId (canonical FK) are both
// optional; exactly one is expected to be set per row. Legacy/seed-created rows
// keep accountId. Transactions synced for real Plaid-linked accounts (which only
// ever have a FinancialAccount, not a legacy Account) set financialAccountId
// instead. accountId was loosened from required to optional to allow this —
// no existing data is affected, every pre-existing row already has accountId set.
// Data-layer code normalizes both back to a single accountId field on read.
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id          String              @id @default(cuid())
  accountId   String?
  account     Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)

  financialAccountId String?
  financialAccount   FinancialAccount? @relation("FinancialAccountTransactions", fields: [financialAccountId], references: [id], onDelete: Cascade)

  date        DateTime            @db.Date
  merchant    String
  description String?
  category    TransactionCategory
  amount      Float
  pending     Boolean             @default(false)

  plaidTransactionId String? @unique // prevents duplicate inserts on re-sync

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([accountId, date])
  @@index([financialAccountId])
  @@index([financialAccountId, date])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────────────────────
// SpaceSnapshot (renamed from WorkspaceSnapshot, itself renamed from DailySnapshot)
// Written once per day by the background sync job.
// spaceId replaces userId — snapshots belong to the Space, not the user.
// ─────────────────────────────────────────────────────────────────────────────

model SpaceSnapshot {
  id      String   @id @default(cuid())
  spaceId String   @map("workspaceId")
  space   Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date

  // Portfolio breakdown
  stocks Float @default(0) // sum of investment account balances
  crypto Float @default(0) // sum of crypto account balances
  total  Float @default(0) // stocks + crypto

  // Banking breakdown
  cash    Float @default(0) // sum of checking balances
  savings Float @default(0) // sum of savings balances
  debt    Float @default(0) // absolute value of debt balances

  // Derived — pre-computed for fast chart queries
  netWorth    Float @default(0) // stocks + crypto + cash + savings − debt
  totalAssets Float @default(0) // stocks + crypto + cash + savings
  cashOnHand  Float @default(0) // max(cash − expense_buffer, 0) — renamed from cashToPlay (legacy "play cash" language)
  netLiquid   Float @default(0) // cash + savings − debt

  createdAt DateTime @default(now())

  @@unique([spaceId, date])
  @@index([spaceId, date])
  @@map("WorkspaceSnapshot")
}

// ─────────────────────────────────────────────────────────────────────────────
// AiAdvice
// One record per advice engine run. Belongs to a Space and is attributed
// to the Space's AiAgent. userId removed — advice is Space-scoped.
// ─────────────────────────────────────────────────────────────────────────────

model AiAdvice {
  id          String    @id @default(cuid())
  spaceId     String    @map("workspaceId")
  space       Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  agentId     String
  agent       AiAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  summary     String
  adviceText  String    @db.Text
  riskLevel   RiskLevel
  actionReady Boolean   @default(false) // renamed from playReady (legacy "play cash" language)
  generatedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([spaceId, generatedAt])
  @@index([agentId, generatedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CreditScore
// Replaces User.ficoScore. Time-series: each manual or API update is a new
// row. source records where the score came from (app, bureau, manual).
// ─────────────────────────────────────────────────────────────────────────────

model CreditScore {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score      Int                      // 300–850
  source     String   @default("manual") // "manual" | "chase_app" | "amex_app" | "experian"
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog
// Append-only log of security-relevant events. NEVER cascade-deleted when a
// user or Space is removed — userId and spaceId are SET NULL instead.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  spaceId           String?  @map("workspaceId")
  space             Space?   @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  action            String   // See AuditAction constants in lib/audit-actions.ts
  metadata          Json?    // e.g. { institution: "Chase", accountCount: 3 }
  ipAddress         String?
  userAgent         String?
  performedByAdminId String? // set when a SYSTEM_ADMIN performs an action on behalf of another user
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([spaceId, createdAt])
  @@index([action, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// RecoveryCode
// One-time backup codes generated when a user enables or regenerates 2FA.
// Codes are shown once in plaintext, then stored as bcrypt hashes.
// Each code can be used once — usedAt is set on redemption.
// Regenerating codes invalidates all existing unused codes.
// ─────────────────────────────────────────────────────────────────────────────

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    // bcrypt hash (cost 10) of the plaintext code — NEVER stored as plaintext
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([userId])
  @@index([userId, usedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// UserSession
// Tracks active sessions for session management UI and admin revocation.
// Written on login. revokedAt is set when a session is force-terminated.
// Note: JWT sessions cannot be invalidated mid-token-lifetime without a
// blocklist or short-lived tokens. This table is informational for now;
// full revocation requires a token blocklist (see security limitations).
// ─────────────────────────────────────────────────────────────────────────────

model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String    @unique  // random opaque identifier (not the JWT itself)
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime  @default(now())
  revokedAt    DateTime?
  revokedById  String?   // admin userId who revoked this session
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([userId, revokedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PlatformSetting
// Key-value store for platform-wide security and feature toggles.
// Managed exclusively by SYSTEM_ADMIN via /admin/security.
// Keys are defined as constants in lib/platform-settings.ts.
// ─────────────────────────────────────────────────────────────────────────────

model PlatformSetting {
  key       String   @id  // e.g. "require_totp_system_admin"
  value     String        // "true" | "false" | numeric string
  updatedAt DateTime @updatedAt
  updatedById String?     // userId of last admin who changed this setting
}
