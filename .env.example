# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev (Docker): all three vars below drive docker-compose.
# Staging/production (Supabase): set DATABASE_URL and DIRECT_URL only;
# the POSTGRES_* vars are not used outside of Docker.
POSTGRES_USER=fintracker
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=fintracker

# DATABASE_URL — used by Prisma at runtime (queries).
# Local dev: postgresql://<user>:<password>@localhost:5432/<db>?schema=public
# Staging (Supabase Transaction Pooler, port 6543):
#   postgresql://<user>:<password>@<project>.pooler.supabase.com:6543/<db>?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://fintracker:change_me_strong_password@localhost:5432/fintracker?schema=public"

# DIRECT_URL — used by Prisma for migrations only (prisma migrate deploy).
# Local dev: same as DATABASE_URL.
# Staging (Supabase Direct Connection, port 5432):
#   postgresql://<user>:<password>@<project>.supabase.com:5432/<db>
DIRECT_URL="postgresql://fintracker:change_me_strong_password@localhost:5432/fintracker?schema=public"

# ── Dev allowed origins (LAN access) ─────────────────────────────────────────
# Comma-separated IPs/hostnames added to Next.js allowedDevOrigins.
# Lets mobile devices on your LAN connect to the dev server.
# Only used in development. Not needed in staging/production.
# Example: DEV_ALLOWED_ORIGINS=192.168.1.100,192.168.1.105
DEV_ALLOWED_ORIGINS=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl

# NEXTAUTH_URL: Required in production (enforced at boot by validateEnv, OPS-1
# S6, along with NEXT_PUBLIC_APP_URL). Set to your Vercel domain (or custom domain).
# In dev it's optional (NextAuth auto-detects from the request Host header), but
# setting it to http://localhost:3000 silences the noisy [next-auth][warn] log.
# Example (prod): NEXTAUTH_URL=https://fintracker-abc123.vercel.app
# Example (local dev): NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL=

# ── App public URL ────────────────────────────────────────────────────────────
# Used for Open Graph metadata and absolute URLs in emails/notifications.
# In dev: http://localhost:3000
# In staging/production: https://<your-vercel-domain>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Token encryption (AES-256-GCM) ───────────────────────────────────────────
# Used to encrypt Plaid access tokens before storing in the DB.
# Generate: openssl rand -hex 32   (exactly 64 hex chars)
# WARNING: changing this in production invalidates all stored Plaid tokens.
ENCRYPTION_KEY=change_me_64_hex_chars

# ── Plaid ─────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# PLAID_ENV: sandbox | development | production
PLAID_ENV=sandbox

# Required for OAuth institutions (Chase, BoA, Wells Fargo, Capital One, etc.).
# Must be an HTTPS URL pointing to /plaid-oauth-return and registered in:
#   Plaid Dashboard → Team → API → Allowed redirect URIs
# Leave blank in sandbox (non-OAuth institutions don't need it).
# Staging example: PLAID_REDIRECT_URI=https://fintracker-abc123.vercel.app/plaid-oauth-return
PLAID_REDIRECT_URI=

# Public HTTPS URL Plaid POSTs webhooks to (TRANSACTIONS/SYNC_UPDATES_AVAILABLE
# → /api/plaid/webhook), so Plaid can tell the app when the deeper 730-day
# history window has finished ingesting and it should re-sync. Optional:
#   - When set, it is used verbatim (must be the full webhook URL).
#   - When blank, it is derived from NEXT_PUBLIC_APP_URL + /api/plaid/webhook.
# Plaid can only reach a PUBLIC HTTPS host, so a localhost/http value is ignored
# and no webhook is registered — local dev needs a tunnel (e.g. ngrok) to
# receive real inbound webhooks; without one, the manual "Sync Now"/daily-cron
# fallbacks still work, just without the push trigger.
# Example: PLAID_WEBHOOK_URL=https://fintracker-abc123.vercel.app/api/plaid/webhook
PLAID_WEBHOOK_URL=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Set to "true" to block all SYSTEM_ADMIN logins. Recommended for production.
DISABLE_SYSTEM_ADMIN=true

# ── Merchant Operations (MI2 S2) ──────────────────────────────────────────────
# The id of the Space that gates the merchant-merge review surface
# (/merchant-ops). Access is membership in this Space — NOT role === SYSTEM_ADMIN.
# SYSTEM_ADMIN creates the Space, sets this, and grants membership. Unset ⇒ the
# surface fails closed (no one can review). No schema; configuration only.
MERCHANT_OPS_SPACE_ID=

# ── Scheduled jobs (Vercel Cron) ──────────────────────────────────────────────
# Authorizes GET /api/jobs/sync-banks. Vercel sends this automatically as
# `Authorization: Bearer <value>` on cron-triggered requests once set as a
# project env var — set it there too, same value. Not used outside Vercel
# Cron; local dev/manual sync use the existing /api/plaid/sync route instead.
# Generate: openssl rand -hex 32
# REQUIRED IN PRODUCTION (enforced at boot by validateEnv, OPS-1 S6) — the
# vercel.json cron jobs 401 without it.
CRON_SECRET=change_me_random_hex

# Seed script passwords — only used by prisma/seed.ts (never run seed in production).
SEED_USER_PASSWORD=FinTracker_User_2026!
SEED_ADMIN_PASSWORD=FinTracker_Admin_2026!

# ── AI (D4 Space-Scoped Chat + Advice Engine) ────────────────────────────────
OPENAI_API_KEY=

# ── Crypto wallet sync ────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=
HELIUS_API_KEY=
# BTC wallet balance sync v1 (lib/crypto/btc-explorer.ts). Defaults are keyless
# (mempool.space) — leave blank to use them. Override only to point at a
# self-hosted explorer / alternate price source or to tune the request timeout.
BTC_EXPLORER_BASE_URL=
BTC_PRICE_URL=
BTC_SYNC_TIMEOUT_MS=
# xpub discovery (v4). Single-address wallets use mempool.space above; xpub
# discovery derives addresses locally and batch-looks-up usage+balance via a
# multiaddr-style provider (blockchain.info, keyless default). All optional:
BTC_BATCH_API_URL=           # batch provider base (default https://blockchain.info)
BTC_RATE_LIMIT_RETRIES=      # 429/503 backoff retries (default 4)
BTC_RATE_LIMIT_BACKOFF_MS=   # base backoff, doubled per attempt (default 500)
BTC_XPUB_GAP_LIMIT=          # consecutive-unused gap (default 20, BIP44)
BTC_XPUB_STEP=               # max NEW indices scanned per branch per run (default 50)
BTC_TX_ADDR_CAP=             # max addresses to import txs for per run (default 25)

# ── Transactional email (OPS-1) ──────────────────────────────────────────────
# Resend API key for outbound transactional email. Read ONLY by
# lib/email/providers/resend.ts (the single Resend SDK import site).
# When UNSET, lib/email/send.ts falls back to the capture transport — it records
# messages in memory instead of sending, so local dev and CI need no credentials.
# Get one at https://resend.com/api-keys
# REQUIRED IN PRODUCTION (enforced at boot by validateEnv, OPS-1 S6) — without
# it password-reset/verification email silently doesn't send.
RESEND_API_KEY=
# Optional override for the default From identity. Leave blank to use the
# per-purpose sender map in lib/email/senders.ts (e.g. support@fourthmeridian.com).
EMAIL_FROM_DEFAULT=

# ── Rate limiting (OPS-1 S4) ─────────────────────────────────────────────────
# Polarity is production-safe by default (lib/rate-limit.ts):
#   - production (NODE_ENV=production): limiting is ACTIVE unless
#     RATE_LIMIT_ENABLED=false — the explicit opt-out is an emergency valve
#     only, and validateEnv() warns loudly when it is set in production.
#   - dev/test: limiting is OFF unless RATE_LIMIT_ENABLED=true.
# Backends: production uses the RateLimit DB table (safe across serverless
# instances); dev/test use an in-memory map. Store errors fail OPEN (an outage
# in the limiter never takes down an endpoint) and are logged.
RATE_LIMIT_ENABLED=
# RATE_LIMIT_SHADOW=true → log-only mode: over-limit requests are counted and
# logged as "[rate-limit] SHADOW ..." but never blocked. Use to measure real
# traffic before enforcing. Leave unset to enforce.
RATE_LIMIT_SHADOW=

# ── FX rate archive (MC1 Phase 1) ────────────────────────────────────────────
# Open Exchange Rates app id — primary FX provider (free tier is sufficient:
# one request per day + historical backfill; https://openexchangerates.org).
# When unset, the FX layer degrades to the keyless Frankfurter/ECB failover,
# which covers the ECB currency subset only (no SAR/AED).
OXR_APP_ID=your_app_id_here

# ── Investment history pipeline (A1 / A3 / A4) ───────────────────────────────
# Per-holding historical investment values. Three independent kill switches
# (each "true" to enable; absent/anything-else = off). The connect flow captures
# day-one PositionObservations and ingests canonical InvestmentEvents inline,
# then the deferred background path reconstructs true day-by-day share quantity.
#   INVESTMENT_OBSERVATIONS_ENABLED    — dark-write PositionObservation capture (A1)
#   INVESTMENT_EVENTS_ENABLED          — canonical InvestmentEvent ingest (A3)
#   INVESTMENT_RECONSTRUCTION_ENABLED  — backward-walk DERIVED quantity history (A4);
#     safe to enable — it refuses to guess past an uninvertible corporate action
#     (marks the position incomplete) rather than fabricating a quantity, and
#     only ever rewrites its own DERIVED rows.
INVESTMENT_OBSERVATIONS_ENABLED=true
INVESTMENT_EVENTS_ENABLED=true
INVESTMENT_RECONSTRUCTION_ENABLED=true

# ── Wealth history regeneration (A9) ─────────────────────────────────────────
# Replaces the flat-held investment component of estimated historical Space
# snapshots with the canonical A8 per-day valuation (per-day reconstructed share
# quantity × per-day price). Enabled now that both real inputs exist (A4
# reconstruction above + a real price vendor, TIINGO_API_KEY). Safe: it never
# touches a frozen observed row, never fabricates a value when position evidence
# doesn't reach a day (the flat estimate is preserved), and keeps every
# reconstructed day labeled isEstimated=true (a derived date is never presented
# as observed).
WEALTH_REGENERATION_ENABLED=true
