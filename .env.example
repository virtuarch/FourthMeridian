# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
# These three are used by docker-compose to create the database
POSTGRES_USER=fintracker
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=fintracker

# Prisma connection string — keep in sync with the three values above
DATABASE_URL="postgresql://fintracker:change_me_strong_password@localhost:5432/fintracker?schema=public"

# ── Dev allowed origins (LAN access) ─────────────────────────────────────────
# Comma-separated IPs/hostnames added to Next.js allowedDevOrigins.
# Lets mobile devices on your LAN connect to the dev server.
# Not needed in production (set real domain in NEXTAUTH_URL instead).
# Example: DEV_ALLOWED_ORIGINS=192.168.1.100,192.168.1.105
DEV_ALLOWED_ORIGINS=

# ── NextAuth (M2) ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl
# NEXTAUTH_URL: Set this in production to your public domain (e.g. https://app.example.com).
# In dev, omit it — NextAuth auto-detects from the request Host header,
# which makes logout redirects work correctly on both localhost and LAN IPs.
# NEXTAUTH_URL=https://app.example.com

# ── Token encryption (AES-256-GCM) ───────────────────────────────────────────
# Used to encrypt Plaid access tokens before storing in the DB
# Generate: openssl rand -hex 32   (exactly 64 hex chars)
ENCRYPTION_KEY=change_me_64_hex_chars

# ── Plaid (M5) ────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# Required for OAuth institutions (Chase, BoA, Wells Fargo, etc.) in production.
# Must be an HTTPS URL pointing to /plaid-oauth-return and registered in the Plaid Dashboard.
# In sandbox with non-OAuth institutions this can be left blank.
# Example (local dev via Cloudflare tunnel): PLAID_REDIRECT_URI=https://xyz.your-tunnel.com/plaid-oauth-return
PLAID_REDIRECT_URI=

# ── Seed passwords (M2) ──────────────────────────────────────────────────────
# Used by prisma/seed.ts — override these before seeding in production
SEED_USER_PASSWORD=FinTracker_User_2026!
SEED_ADMIN_PASSWORD=FinTracker_Admin_2026!

# ── System admin kill switch (M2) ────────────────────────────────────────────
# Set to "true" to block all SYSTEM_ADMIN logins (safe default for production)
DISABLE_SYSTEM_ADMIN=false

# ── AI Advice Engine (M9) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Crypto wallet sync (M6) ───────────────────────────────────────────────────
ETHERSCAN_API_KEY=
HELIUS_API_KEY=
