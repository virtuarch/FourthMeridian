# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev (Docker): all three vars below drive docker-compose.
# Staging/production (Supabase): set DATABASE_URL and DIRECT_URL only;
# the POSTGRES_* vars are not used outside of Docker.
POSTGRES_USER=fintracker
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=fintracker

# DATABASE_URL — used by Prisma at runtime (queries).
# Local dev: postgresql://<user>:<password>@localhost:5432/<db>?schema=public
# Staging (Supabase Transaction Pooler, port 6543):
#   postgresql://<user>:<password>@<project>.pooler.supabase.com:6543/<db>?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://fintracker:change_me_strong_password@localhost:5432/fintracker?schema=public"

# DIRECT_URL — used by Prisma for migrations only (prisma migrate deploy).
# Local dev: same as DATABASE_URL.
# Staging (Supabase Direct Connection, port 5432):
#   postgresql://<user>:<password>@<project>.supabase.com:5432/<db>
DIRECT_URL="postgresql://fintracker:change_me_strong_password@localhost:5432/fintracker?schema=public"

# ── Dev allowed origins (LAN access) ─────────────────────────────────────────
# Comma-separated IPs/hostnames added to Next.js allowedDevOrigins.
# Lets mobile devices on your LAN connect to the dev server.
# Only used in development. Not needed in staging/production.
# Example: DEV_ALLOWED_ORIGINS=192.168.1.100,192.168.1.105
DEV_ALLOWED_ORIGINS=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl

# NEXTAUTH_URL: Required in production. Set to your Vercel domain (or custom domain).
# In dev it's optional (NextAuth auto-detects from the request Host header), but
# setting it to http://localhost:3000 silences the noisy [next-auth][warn] log.
# Example (prod): NEXTAUTH_URL=https://fintracker-abc123.vercel.app
# Example (local dev): NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL=

# ── App public URL ────────────────────────────────────────────────────────────
# Used for Open Graph metadata and absolute URLs in emails/notifications.
# In dev: http://localhost:3000
# In staging/production: https://<your-vercel-domain>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Token encryption (AES-256-GCM) ───────────────────────────────────────────
# Used to encrypt Plaid access tokens before storing in the DB.
# Generate: openssl rand -hex 32   (exactly 64 hex chars)
# WARNING: changing this in production invalidates all stored Plaid tokens.
ENCRYPTION_KEY=change_me_64_hex_chars

# ── Plaid ─────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# PLAID_ENV: sandbox | development | production
PLAID_ENV=sandbox

# Required for OAuth institutions (Chase, BoA, Wells Fargo, Capital One, etc.).
# Must be an HTTPS URL pointing to /plaid-oauth-return and registered in:
#   Plaid Dashboard → Team → API → Allowed redirect URIs
# Leave blank in sandbox (non-OAuth institutions don't need it).
# Staging example: PLAID_REDIRECT_URI=https://fintracker-abc123.vercel.app/plaid-oauth-return
PLAID_REDIRECT_URI=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Set to "true" to block all SYSTEM_ADMIN logins. Recommended for production.
DISABLE_SYSTEM_ADMIN=true

# ── Scheduled jobs (Vercel Cron) ──────────────────────────────────────────────
# Authorizes GET /api/jobs/sync-banks. Vercel sends this automatically as
# `Authorization: Bearer <value>` on cron-triggered requests once set as a
# project env var — set it there too, same value. Not used outside Vercel
# Cron; local dev/manual sync use the existing /api/plaid/sync route instead.
# Generate: openssl rand -hex 32
CRON_SECRET=change_me_random_hex

# Seed script passwords — only used by prisma/seed.ts (never run seed in production).
SEED_USER_PASSWORD=FinTracker_User_2026!
SEED_ADMIN_PASSWORD=FinTracker_Admin_2026!

# ── AI (D4 Space-Scoped Chat + Advice Engine) ────────────────────────────────
OPENAI_API_KEY=

# ── Crypto wallet sync ────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=
HELIUS_API_KEY=

# ── FX rate archive (MC1 Phase 1) ────────────────────────────────────────────
# Open Exchange Rates app id — primary FX provider (free tier is sufficient:
# one request per day + historical backfill; https://openexchangerates.org).
# When unset, the FX layer degrades to the keyless Frankfurter/ECB failover,
# which covers the ECB currency subset only (no SAR/AED).
OXR_APP_ID=your_app_id_here
