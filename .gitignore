# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production / build outputs
/build
/dist
/out

# misc
*.pem

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets, never commit
.env
.env.*
# Allow the safe template — no real secrets inside
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client (re-generated on install)
node_modules/.prisma

# macOS
.DS_Store
**/.DS_Store
# macOS temp files created by some editors when saving (e.g. vim on APFS mounts)
**/.fuse_hidden*

# Working / design artefacts — not part of the source distribution
# Root-level copies that couldn't be deleted (APFS volume restriction in sandbox)
*.sketch
Daily Brief Dashboard Mock Up.png
Oval World Image*.png
QA_PASS_*.md
WIDGET_META_ANALYSIS.md
WORKSPACE_STATUS.md
WORKSPACE_TYPE_SPEC.md

# Archive folder — local working notes and design assets, never publish
docs/archive/

# Cloudflare tunnel credentials (contain real cert/token)
cloudflared/*.json
cloudflared/*.pem
cloudflared/cert.pem

# Deprecated stub files (superseded by lib/plaid/ and lib/db.ts)
lib/plaid.ts
lib/encryption.ts
lib/prisma.ts
app/api/plaid/create-link-token/
