# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production / build outputs
/build
/dist
/out

# misc
*.pem

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets, never commit
.env
.env.*
# Allow the safe template — no real secrets inside
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client (re-generated on install)
node_modules/.prisma

# macOS
.DS_Store
**/.DS_Store

# Cloudflare tunnel credentials (contain real cert/token)
cloudflared/*.json
cloudflared/*.pem
cloudflared/cert.pem
